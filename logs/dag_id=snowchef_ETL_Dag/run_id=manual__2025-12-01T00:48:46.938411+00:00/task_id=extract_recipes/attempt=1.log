[2025-12-01T00:48:55.753+0000] {python.py:240} INFO - Done. Returned value was: [{'id': 's_715415', 'title': 'Red Lentil Soup with Chicken and Turnips', 'instructions': 'To a large dutch oven or soup pot, heat the olive oil over medium heat. Add the onion, carrots and celery and cook for 8-10 minutes or until tender, stirring occasionally. Add the garlic and cook for an additional 2 minutes, or until fragrant. Season conservatively with a pinch of salt and black pepper.To the pot, add the tomatoes, turnip and red lentils. Stir to combine. Stir in the vegetable stock and increase the heat on the stove to high. Bring the soup to a boil and then reduce to a simmer. Simmer for 20 minutes or until the turnips are tender and the lentils are cooked through. Add the chicken breast and parsley. Cook for an additional 5 minutes. Adjust seasoning to taste. Serve the soup immediately garnished with fresh parsley and any additional toppings. Enjoy!', 'servings': 8, 'url': 'https://www.pinkwhen.com/red-lentil-soup-with-chicken-and-turnips/', 'cuisine': '', 'diets': ['gluten free', 'dairy free'], 'ingredients': [{'id': 's_9037', 'name': 'additional toppings: avocado', 'quantity': 8.0, 'unit': 'servings', 'raw': 'additional toppings: diced avocado, micro greens, chopped basil)'}, {'id': 's_11124', 'name': 'carrots', 'quantity': 3.0, 'unit': 'medium', 'raw': '3 medium carrots, peeled and diced'}, {'id': 's_10111143', 'name': 'celery stalks', 'quantity': 3.0, 'unit': '', 'raw': '3 celery stalks, diced'}, {'id': 's_5064', 'name': 'chicken breast', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups fully-cooked chicken breast, shredded (may be omitted for a vegetarian version)'}, {'id': 's_10311297', 'name': 'flat leaf parsley', 'quantity': 0.5, 'unit': 'cup', 'raw': '½ cup flat leaf Italian parsley, chopped (plus extra for garnish)'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 6.0, 'unit': 'cloves', 'raw': '6 cloves of garlic, finely minced'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons olive oil'}, {'id': 's_10011693', 'name': 'canned tomatoes', 'quantity': 28.0, 'unit': 'ounce', 'raw': '28 ounce-can plum tomatoes, drained and rinsed, chopped'}, {'id': 's_10016069', 'name': 'lentils', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups dried red lentils, rinsed'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 8.0, 'unit': 'servings', 'raw': 'salt and black pepper, to taste'}, {'id': 's_11564', 'name': 'turnip', 'quantity': 1.0, 'unit': 'large', 'raw': '1 large turnip, peeled and diced'}, {'id': 's_6615', 'name': 'vegetable stock', 'quantity': 8.0, 'unit': 'cups', 'raw': '8 cups vegetable stock'}, {'id': 's_10511282', 'name': 'onion', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium yellow onion, diced'}]}, {'id': 's_716406', 'title': 'Asparagus and Pea Soup: Real Convenience Food', 'instructions': "Chop the garlic and onions. Saute the onions in the EVOO, adding the garlic after a couple of minutes; cook until the onions are translucent. Add the whole bag of asparagus and cover everything with the broth. Season with salt and pepper and a pinch of red pepper flakes, if using.Simmer until the asparagus is bright green and tender (if you've thawed the asparagus it will only take a couple of minutes). Turn off the heat and puree using an immersion blender. Add peas (the heat of the soup will quickly thaw them) and puree until smooth; add more until it reaches the thickness you like.Top with chives and a small dollop of creme fraiche or sour cream or greek yogurt.", 'servings': 2, 'url': 'https://fullbellysisters.blogspot.com/2011/03/asparagus-and-pea-soup-real-convenience.html', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'vegan'], 'ingredients': [{'id': 's_11011', 'name': 'asparagus', 'quantity': 1.0, 'unit': 'bag', 'raw': '1 bag of frozen organic asparagus (preferably thawed)'}, {'id': 's_1034053', 'name': 'evoo', 'quantity': 1.0, 'unit': 't', 'raw': '1T EVOO (extra virgin olive oil)'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 2.0, 'unit': 'cloves', 'raw': 'a couple of garlic cloves'}, {'id': 's_11282', 'name': 'onion', 'quantity': 0.5, 'unit': '', 'raw': '1/2 onion'}, {'id': 's_11304', 'name': 'peas', 'quantity': 2.0, 'unit': 'c', 'raw': '2-3c of frozen organic peas'}, {'id': 's_99253', 'name': 'vegetable broth', 'quantity': 1.0, 'unit': 'box', 'raw': '1 box low-sodium vegetable broth'}]}, {'id': 's_644387', 'title': 'Garlicky Kale', 'instructions': 'Heat the olive oil in a large pot over medium heat. Add the kale and cover.Stir occasionally until the volume of the kale is reduced by half. Uncover. Add garlic and basalmic.Allow to cook for about another 30 seconds or so, mixing well so that the garlic and vinegar are well distributed. Serve hot.', 'servings': 2, 'url': 'https://www.foodista.com/recipe/J2FTJBF7/garlicky-kale', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'whole 30', 'vegan'], 'ingredients': [{'id': 's_2069', 'name': 'balsamic vinegar', 'quantity': 3.0, 'unit': 'tablespoons', 'raw': '3 tablespoons balsamic vinegar'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 1.0, 'unit': 'clove', 'raw': '1 clove garlic, minced'}, {'id': 's_11233', 'name': 'curly kale', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch curly kale, stems removed and chopped'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'servings', 'raw': 'Olive oil'}]}, {'id': 's_715446', 'title': 'Slow Cooker Beef Stew', 'instructions': "To get started, heat your slow cooker to low. Pour in the cream of mushroom soup, Dale's seasoning, water, and beef broth and stir until mixed well. Add in your stew meat, potatoes, onions, carrots, celery, and green onions. Stir well until covered and cook on low for 8 hours. You can add salt and pepper as desired, but the flavors and the Dale's marry together so well that you probably won’t need them.", 'servings': 6, 'url': 'https://www.pinkwhen.com/slow-cooker-beef-stew-recipe/', 'cuisine': '', 'diets': ['gluten free', 'dairy free'], 'ingredients': [{'id': 's_6008', 'name': 'beef broth', 'quantity': 14.5, 'unit': 'oz', 'raw': '1 14.5oz can of Beef Broth'}, {'id': 's_11124', 'name': 'carrots', 'quantity': 2.0, 'unit': 'large', 'raw': '2 large carrots, chopped'}, {'id': 's_11143', 'name': 'celery', 'quantity': 2.0, 'unit': 'stalks', 'raw': '2 stalks celery, chopped'}, {'id': 's_6147', 'name': 'cream of mushroom soup', 'quantity': 26.0, 'unit': 'oz', 'raw': '1 26oz can Cream of Mushroom Soup'}, {'id': 's_11291', 'name': 'green onions', 'quantity': 3.0, 'unit': '', 'raw': '3 green onions, chopped'}, {'id': 's_10211352', 'name': 'new potatoes', 'quantity': 10.0, 'unit': '', 'raw': '10 new (red)potatoes'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': 'small', 'raw': '1 small onion chopped'}, {'id': 's_1042027', 'name': "dale's seasoning", 'quantity': 0.5, 'unit': 'cup', 'raw': "½ cup Dale's Seasoning"}, {'id': 's_10023618', 'name': 'stew meat', 'quantity': 2.0, 'unit': 'pounds', 'raw': '2 pounds stew meat'}, {'id': 's_14412', 'name': 'water', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups water'}]}, {'id': 's_782601', 'title': 'Red Kidney Bean Jambalaya', 'instructions': 'Rinse the kidney beans and brown rice separately. Cover the kidney beans with water and soak for 8 hours or overnight. In a separate bowl, cover the brown rice with water and soak for 8 hours or overnight. Drain and rinse the kidney beans, then transfer to a medium saucepan and cover with fresh water. Bring to a boil, reduce heat to medium-low, cover, and simmer for 1 hour or until just tender but not falling apart. Drain and set aside. Heat the oil in a large saucepan over medium heat. When hot, add the onion and saut for 5 minutes. Now add the garlic, carrots, celery and green beans, and stir for another 5 minutes. Next add the tomatoes, red pepper, eggplant, sage, thyme, marjoram and celery seed, and continue to stir for another few minutes. Pour in the vegetable stock, liquid smoke, rice and the cooked kidney beans. Bring to a boil, reduce heat to medium low, cover, and cook, stirring occasionally, for 45 minutes or until the rice is tender. Add water as necessary if the stew becomes too dry.Season with sriracha, salt and pepper, and taste for seasoning  add more liquid smoke, sriracha, salt, pepper or herbs as desired.', 'servings': 6, 'url': 'https://www.foodandspice.com/2016/05/red-kidney-bean-jambalaya.html', 'cuisine': 'creole', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_20041', 'name': 'brown rice', 'quantity': 2.0, 'unit': 'cups', 'raw': '2/3 cup dried brown rice (2 cups cooked)'}, {'id': 's_11124', 'name': 'carrots', 'quantity': 2.0, 'unit': 'medium', 'raw': '2 medium carrots, sliced'}, {'id': 's_11143', 'name': 'celery', 'quantity': 2.0, 'unit': 'stalks', 'raw': '2 stalks celery, sliced'}, {'id': 's_2007', 'name': 'celery seed', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon celery seed'}, {'id': 's_16032', 'name': 'kidney beans', 'quantity': 2.0, 'unit': 'cups', 'raw': '2/3 cup dried kidney beans (2 cups cooked)'}, {'id': 's_1002023', 'name': 'marjoram', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon dried marjoram'}, {'id': 's_2042', 'name': 'thyme', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons dried thyme'}, {'id': 's_11209', 'name': 'eggplant', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium eggplant, chopped'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 2.0, 'unit': 'cloves', 'raw': '2 cloves garlic, minced or crushed'}, {'id': 's_11052', 'name': 'green beans', 'quantity': 3.0, 'unit': 'handfuls', 'raw': '3 handfuls of green beans, chopped'}, {'id': 's_1002030', 'name': 'ground pepper', 'quantity': 6.0, 'unit': 'servings', 'raw': 'fresh ground black pepper'}, {'id': 's_1012038', 'name': 'ground sage', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons ground sage'}, {'id': 's_93627', 'name': 'liquid smoke', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 to 1 teaspoon liquid smoke, to taste'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons olive oil'}, {'id': 's_11821', 'name': 'bell pepper', 'quantity': 1.0, 'unit': '', 'raw': '1 red bell pepper, seeded and chopped'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': 'small', 'raw': '1 small white or red onion, diced'}, {'id': 's_1012047', 'name': 'sea salt', 'quantity': 1.5, 'unit': 'teaspoons', 'raw': '1 1/2 teaspoons sea salt, or to taste'}, {'id': 's_6168', 'name': 'sriracha', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon sriracha or other hot sauce'}, {'id': 's_11529', 'name': 'tomatoes', 'quantity': 2.0, 'unit': 'medium', 'raw': '2 medium tomatoes, diced'}, {'id': 's_6615', 'name': 'vegetable stock', 'quantity': 3.0, 'unit': 'cups', 'raw': '3 cups vegetable stock'}]}, {'id': 's_716426', 'title': 'Cauliflower, Brown Rice, and Vegetable Fried Rice', 'instructions': 'Remove the cauliflower\'s tough stem and reserve for another use. Using a food processor, pulse cauliflower florets until they resemble rice or couscous. You should end up with around four cups of "cauliflower rice." Heat 1T butter and 1T oil in a large skillet over medium heat. Add garlic and the white and light green pieces of scallion. Sauté about a minute. Add the cauliflower to the pan. Stir to coat with oil, then spread out in pan and let sit; you want it cook a bit and to caramelize (get a bit brown), which will bring out the sweetness. After a couple of minutes, stir and spread out again. Add cold rice (it separates easily, so it won\'t clump up during cooking), plus the additional grapeseed and coconut oil or butter. Raise heat to medium-high. Toss everything together and, again, spread the mixture out over the whole pan and press a bit into the bottom. Let it sit for about two minutes—so the rice can get toasted and a little crispy. Add the peas and broccoli and stir again. Drizzle soy sauce and toasted sesame oil over rice.Cook for another minute or so and turn off heat. Add chopped scallion tops and toss.I like to toast some sesame seeds in a dry pan; I sprinkle these and some more raw, chopped scallion over the top of the rice for added flavor and crunch.Season to taste with salt and, if you\'d like, more soy sauce. Keep in mind that if you\'re serving this with something salty and saucy (ie. teriyaki chicken) you may want to hold off on adding too much salt to the fried rice.', 'servings': 8, 'url': 'https://fullbellysisters.blogspot.com/2012/01/cauliflower-fried-rice-more-veggies.html', 'cuisine': 'chinese', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_4517', 'name': 'grapeseed oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons grapeseed oil'}, {'id': 's_4047', 'name': 'coconut oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons coconut oil'}, {'id': 's_11291', 'name': 'scallions', 'quantity': 7.0, 'unit': '', 'raw': '7 scallions, chopped (keep white/light green ends separate from dark green tops)'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 5.0, 'unit': 'cloves', 'raw': '5 cloves of garlic, chopped'}, {'id': 's_11135', 'name': 'cauliflower', 'quantity': 1.0, 'unit': 'head', 'raw': 'head of cauliflower, raw'}, {'id': 's_20041', 'name': 'brown rice', 'quantity': 3.0, 'unit': 'cups', 'raw': '3 cups of cooked brown rice, cold'}, {'id': 's_11090', 'name': 'broccoli', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups cooked broccoli, chopped small'}, {'id': 's_11304', 'name': 'peas', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup frozen peas'}, {'id': 's_16424', 'name': 'soy sauce', 'quantity': 3.0, 'unit': 't', 'raw': '3 T reduced-sodium soy sauce'}, {'id': 's_4058', 'name': 'sesame oil', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons toasted sesame oil'}, {'id': 's_12023', 'name': 'sesame seeds', 'quantity': 8.0, 'unit': 'servings', 'raw': 'toasted sesame seeds, optional'}, {'id': 's_11291', 'name': 'additional scallion tops', 'quantity': 8.0, 'unit': 'servings', 'raw': 'additional chopped scallion tops for garnish'}, {'id': 's_2047', 'name': 'salt', 'quantity': 8.0, 'unit': 'servings', 'raw': 'salt, to taste'}]}, {'id': 's_716004', 'title': 'Quinoa and Chickpea Salad with Sun-Dried Tomatoes and Dried Cherries', 'instructions': 'Rinse the quinoa and soak for 8 hours or overnight in 2 cups of water. Rinse the chickpeas and soak for 8 hours or overnight in several inches of water.Rinse the chickpeas and transfer to a small saucepan. Cover with fresh water and bring to a boil. Reduce heat to medium-low, cover, and simmer for 1 hour or until buttery soft.While the chickpeas are cooking, soak the sun-dried tomatoes in hot water for 30 minutes, then drain and chop. Meanwhile, bring the quinoa to a boil in a medium saucepan. Reduce heat to the lowest setting, cover, and simmer for 15 minutes or until the water is absorbed. Remove from heat and wait 5 minutes before fluffing with a fork.Meanwhile, toast the cashews in a dry unoiled skillet or saucepan over medium-low heat, tossing or stirring frequently, for 10 minutes until browned. Transfer the chickpeas, quinoa, sun-dried tomatoes, cashews and dried cherries to a large mixing bowl. Whisk the dressing ingredients together and pour over the salad. Stir to combine and serve at room temperature or chilled.', 'servings': 6, 'url': 'https://www.foodandspice.com/2016/01/quinoa-and-chickpea-salad-with-sun.html', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian'], 'ingredients': [{'id': 's_12087', 'name': 'cashews', 'quantity': 0.33333334, 'unit': 'cup', 'raw': '1/3 cup raw cashews, chopped or left whole'}, {'id': 's_93822', 'name': 'dried cherries', 'quantity': 0.33333334, 'unit': 'cup', 'raw': '1/3 cup dried cherries'}, {'id': 's_16056', 'name': 'dried chickpeas', 'quantity': 1.5, 'unit': 'cups', 'raw': '1/2 cup dried chickpeas (1 1/2 cups cooked or 1 14 oz can)'}, {'id': 's_2042', 'name': 'dried thyme', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon dried thyme'}, {'id': 's_1002014', 'name': 'ground cumin', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon ground cumin'}, {'id': 's_19296', 'name': 'honey', 'quantity': 1.5, 'unit': 'tablespoons', 'raw': '1 1/2 tablespoons honey'}, {'id': 's_9206', 'name': 'juice of orange', 'quantity': 1.0, 'unit': '', 'raw': '1 medium orange, juiced'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons olive oil'}, {'id': 's_20035', 'name': 'quinoa', 'quantity': 2.0, 'unit': 'cups', 'raw': '1 cup dried quinoa (2 cups cooked)'}, {'id': 's_1022068', 'name': 'red wine vinegar', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons red wine vinegar'}, {'id': 's_1012047', 'name': 'sea-salt', 'quantity': 6.0, 'unit': 'servings', 'raw': 'sea salt and fresh cracked black pepper to taste'}, {'id': 's_11955', 'name': 'sun-dried tomatoes', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup sun-dried tomatoes'}, {'id': 's_2043', 'name': 'turmeric', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon turmeric'}]}, {'id': 's_716627', 'title': 'Easy Homemade Rice and Beans', 'instructions': 'Heat the olive oil in a large pot over medium heat. Add onions and saute until soft, or for about 5 minutes. Add all other remaining ingredients and stir together. Increase the heat to medium high and bring to a boil. Cover and reduce heat to medium low so that the mixture simmers. Cook for 15-20 minutes, or until rice is fluffy and liquid is absorbed.* Serve with salsa, cheese, and sour cream.', 'servings': 2, 'url': 'http://cooking2perfection.blogspot.com/2012/11/easy-homemade-rice-and-beans.html', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_16018', 'name': 'black beans', 'quantity': 15.0, 'unit': 'ounce', 'raw': '1 15-ounce can black beans, not drained'}, {'id': 's_10011693', 'name': 'canned tomatoes', 'quantity': 10.0, 'unit': 'ounce', 'raw': '1 10-ounce can Rotel tomatoes with diced green chilies, not drained'}, {'id': 's_2009', 'name': 'chili powder', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp chili powder'}, {'id': 's_1002014', 'name': 'cumin', 'quantity': 0.5, 'unit': 'tsp', 'raw': '1/2 tsp cumin'}, {'id': 's_1002030', 'name': 'ground pepper', 'quantity': 0.25, 'unit': 'tsp', 'raw': '1/4 tsp ground black pepper'}, {'id': 's_6168', 'name': 'optional: of hot sauce', 'quantity': 4.0, 'unit': 'dashes', 'raw': 'optional: 4-5 dashes of hot sauce'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.0, 'unit': 'tsp', 'raw': '1 tsp olive oil'}, {'id': 's_11282', 'name': 'onion', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup onion, chopped'}, {'id': 's_20444', 'name': 'rice', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup uncooked rice'}, {'id': 's_14412', 'name': 'water', 'quantity': 3.0, 'unit': 'tbsp', 'raw': '3 Tbsp water'}]}, {'id': 's_664147', 'title': 'Tuscan White Bean Soup with Olive Oil and Rosemary', 'instructions': 'Rinse the beans thoroughly and place them in a 7-quart slow cooker along with the water, onion, garlic, and bay leaf. Cover and cook on LOW for about 8 hours, or until the beans are nice and tender. Remove the bay leaf. Using a handheld immersion blender, puree the remaining ingredients to the desired texture. Add the salt to taste.Ladle the soup into bowls. Drizzle with the olive oil, sprinkle with rosemary, and serve.', 'servings': 6, 'url': 'https://www.foodista.com/recipe/HPKTNKY5/tuscan-white-bean-soup-with-olive-oil-and-rosemary', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_2004', 'name': 'bay leaf', 'quantity': 1.0, 'unit': '', 'raw': '1 bay leaf'}, {'id': 's_2063', 'name': 'rosemary', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon chopped fresh rosemary'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 6.0, 'unit': 'cloves', 'raw': '6 cloves garlic'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon olive oil'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium onion, chopped'}, {'id': 's_2047', 'name': 'salt', 'quantity': 6.0, 'unit': 'servings', 'raw': 'Salt'}, {'id': 's_14412', 'name': 'water', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons water'}, {'id': 's_10316049', 'name': 'beans', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups dried white beans, such as great northern or cannellini'}]}, {'id': 's_640941', 'title': 'Crunchy Brussels Sprouts Side Dish', 'instructions': 'Blanch the Brussels sprouts in boiling water for 6-8 minutes or in a microwave oven in a little water for about 4 minutes. Drain. Saute the Brussels sprouts, stirring constantly, until they become golden-brown in color.Meanwhile mix the vinegar, mustard, honey and olive oil. Add walnuts to the sprouts, stir and combine. Pour the vinegar dressing over the sprouts, season with pepper. Mix and combine so that each sprout is covered with the dressing. Serve warm or cold as a side dish.', 'servings': 4, 'url': 'https://www.foodista.com/recipe/LKJMG5RP/crunchy-brussels-sprouts', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal'], 'ingredients': [{'id': 's_1002030', 'name': 'pepper', 'quantity': 0.25, 'unit': 'tsp', 'raw': '¼ tsp black pepper'}, {'id': 's_11098', 'name': 'brussels sprouts', 'quantity': 800.0, 'unit': 'g', 'raw': '800 g Brussels sprouts, trimmed (or 1 kg untrimmed)'}, {'id': 's_1032046', 'name': 'dijon mustard', 'quantity': 1.0, 'unit': 'tsp', 'raw': '1 tsp Dijon mustard'}, {'id': 's_19296', 'name': 'honey', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp of honey'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 3.0, 'unit': 'tbs', 'raw': '3 Tbs olive oil'}, {'id': 's_1022068', 'name': 'red wine vinegar', 'quantity': 2.0, 'unit': 'tbs', 'raw': '2 Tbs red wine vinegar'}, {'id': 's_12155', 'name': 'walnuts', 'quantity': 0.25, 'unit': 'cup', 'raw': '¼ cup walnuts, toasted, coarsely chopped'}]}, {'id': 's_660306', 'title': 'Slow Cooker: Pork and Garbanzo Beans', 'instructions': 'In slow cooker layer in this order: pork, then garbanzo beans, onion, pour water over all. Mix spices together and sprinkle over pork and beans. Cover. Set on low and cook for approximately 6 hours. The beans should be tender and creamy. The pork should fall very easily from the bone. The pork can be either shredded for cubed for your preference. *3Serving Suggestion: Scoop about 1 cup of beans with broth into a soup bowl. Top with shredded pork. Add 1/4 of an avocado sliced, top with chopped fresh cilantro.NOTES:*1 The beans do not need to be soaked before adding to the slow cooker. They will be perfectly soft and creamy without pre-soaking.*2 Substitute the water for: 2 cups water and 1 bottle of good quality dark beer like Negra Modelo. You can also substitute the water for chicken stock or pork stock. Each of these substitutions will add an extra dimension of flavor.*3 If you want to shred the pork, it is easiest to do when the pork is hot. Use two forks to pull the pork apart and shred. If you want to slice the pork (like for sandwiches) it is best to do when the pork is cold. Let the pork rest in the refrigerator for several hours or over night. Slice with a serrated knife or a very sharp chef knife.', 'servings': 6, 'url': 'https://www.foodista.com/recipe/6BFKWQ7C/slow-cooker-pork-and-garbanzo-beans', 'cuisine': '', 'diets': ['gluten free', 'dairy free'], 'ingredients': [{'id': 's_2010', 'name': 'cinnamon', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp cinnamon'}, {'id': 's_1002014', 'name': 'cumin', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp dried cumin'}, {'id': 's_16056', 'name': 'garbanzo beans *1', 'quantity': 16.0, 'unit': 'oz', 'raw': '16 oz bag of dried garbanzo beans (rinsed, but not soaked) *1'}, {'id': 's_1002030', 'name': 'ground pepper', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp ground black pepper'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': 'small', 'raw': '1 small onion, sliced'}, {'id': 's_10010225', 'name': 'pork should roast', 'quantity': 3.0, 'unit': 'lb', 'raw': '3lb Pork Should Roast – bone-in'}, {'id': 's_2047', 'name': 'salt', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp salt'}, {'id': 's_14412', 'name': 'water *2', 'quantity': 4.0, 'unit': 'cups', 'raw': '4 cups of water (also see “Notes” at bottom of recipe) *2'}]}, {'id': 's_756814', 'title': 'Powerhouse Almond Matcha Superfood Smoothie', 'instructions': 'Combine all of the ingredients in a blender. Blend on high until smooth. Serve immediately.', 'servings': 2, 'url': 'https://www.foodista.com/blog/2015/05/17/powehouse-almond-matcha-superfood-smoothie', 'cuisine': '', 'diets': ['gluten free', 'dairy free'], 'ingredients': [{'id': 's_12195', 'name': 'natural almond butter', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons unsalted natural almond butter'}, {'id': 's_93607', 'name': 'almond milk', 'quantity': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups unsweetened almond milk'}, {'id': 's_9040', 'name': 'banana', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium frozen banana'}, {'id': 's_12006', 'name': 'chia seeds', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons chia seeds'}, {'id': 's_11233', 'name': 'baby kale', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup baby kale, packed'}, {'id': 's_9176', 'name': 'mango pieces', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup frozen mango pieces'}, {'id': 's_98932', 'name': 'matcha tea powder', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon matcha green tea powder'}, {'id': 's_9266', 'name': 'pineapple', 'quantity': 0.75, 'unit': 'cup', 'raw': '3/4 cup frozen pineapple'}, {'id': 's_2050', 'name': 'vanilla extract', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon vanilla extract'}]}, {'id': 's_715769', 'title': 'Broccolini Quinoa Pilaf', 'instructions': 'In a large pan with lid heat olive oil over medium high heat. Add onions and cook for 1 minute. Add garlic and cook until onions are translucent and garlic is fragrant. Add quinoa to pan, stir to combine. Slowly add in broth and bring to a boil.Cover and reduce heat to low, cook for 15 minutes.In the last 2-3 minutes of cooking add in broccolini on top of the quinoa (do not stir) and cover.Uncover and toss broccolini and quinoa together.Season to taste with salt and pepper. Add walnuts and serve hot.', 'servings': 2, 'url': 'https://pickfreshfoods.com/broccolini-quinoa-pilaf/', 'cuisine': 'mediterranean', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_98840', 'name': 'broccolini', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch broccolini, trimmed'}, {'id': 's_10211215', 'name': 'garlic clove', 'quantity': 1.0, 'unit': '', 'raw': '1 garlic clove, minced'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 tbsp olive oil'}, {'id': 's_11282', 'name': 'onion', 'quantity': 0.5, 'unit': 'cup', 'raw': '½ cup onion'}, {'id': 's_20035', 'name': 'quinoa', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup quinoa, rinsed'}, {'id': 's_6615', 'name': 'vegetable broth', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups vegetable broth'}, {'id': 's_10112155', 'name': 'walnuts', 'quantity': 2.0, 'unit': 'oz', 'raw': '2 oz chopped walnuts'}]}, {'id': 's_642129', 'title': 'Easy To Make Spring Rolls', 'instructions': 'Have all the ingredients ready for assembly. In a large bowl filled with water, dip a wrapper in the water. The rice wrapper will begin to soften and this is your cue to remove it from the water and lay it flat. Place 2 shrimp halves in a row across the center and top with basil, mint, cilantro and lettuce. Leave about 1 to 2 inches uncovered on each side.  Fold uncovered sides inward, then tightly roll the wrapper, beginning at the end with the lettuce.  Repeat with remaining wrappers and ingredients. Cut and serve at room temperature with dipping sauce.The Culinary Chases Note: The rice wrapper can be fussy to handle if you let it soak too long. I usually give it a couple of swishes in the water and then remove. It may feel slightly stiff but by the time you are ready to roll up, the wrapper will become very pliable.  A typical spring roll contains cooked rice vermicelli, slivers of cooked pork and julienned carrots but you can use whatever suits your fancy.  Enjoy!', 'servings': 4, 'url': 'https://www.foodista.com/recipe/B5HHJWNP/easy-to-make-spring-rolls', 'cuisine': 'vietnamese', 'diets': ['gluten free', 'dairy free', 'pescatarian'], 'ingredients': [{'id': 's_2044', 'name': 'you can use regular basil', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup Thai basil or you can use regular basil'}, {'id': 's_11250', 'name': 'boston lettuce', 'quantity': 1.0, 'unit': 'small head', 'raw': 'small head of Boston lettuce, roughly chopped'}, {'id': 's_11819', 'name': 'chili pepper', 'quantity': 1.0, 'unit': 'small', 'raw': 'small chili pepper, finely chopped'}, {'id': 's_6179', 'name': 'fish sauce', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup fish sauce'}, {'id': 's_2012', 'name': 'coriander leaves', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup coriander (cilantro) leaves'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 1.0, 'unit': 'clove', 'raw': '1 clove garlic'}, {'id': 's_9160', 'name': 'lime juice', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons fresh lime juice'}, {'id': 's_2064', 'name': 'mint leaves', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup mint leaves'}, {'id': 's_11821', 'name': 'bell pepper', 'quantity': 4.0, 'unit': 'servings', 'raw': 'red bell pepper, thinly sliced'}, {'id': 's_1022053', 'name': 'rice vinegar', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup rice vinegar'}, {'id': 's_15270', 'name': 'shrimp', 'quantity': 8.0, 'unit': 'large', 'raw': '8 large cooked shrimp, slice in half lengthways'}, {'id': 's_10118368', 'name': 'spring roll wrappers', 'quantity': 8.0, 'unit': '8-inch', 'raw': '8 large (8-inch) spring roll wrappers'}, {'id': 's_19335', 'name': 'sugar', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon sugar'}, {'id': 's_14412', 'name': 'water', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup water'}, {'id': 's_-1', 'name': 'nuoc cham', 'quantity': 4.0, 'unit': 'servings', 'raw': 'Nuoc Cham (dipping sauce)'}, {'id': 's_-1', 'name': 'nuoc cham', 'quantity': 4.0, 'unit': 'servings', 'raw': 'Nuoc Cham (dipping sauce)'}]}, {'id': 's_642605', 'title': 'Farro With Mushrooms and Asparagus', 'instructions': 'In a small bowl, cover dried mushrooms with warm water.  Soak for 25 minutes, or until softened. Drain the mushrooms, and discard the soaking water.  Chop finely.Bring a large pot of water to a boil. Add farro, and cook for 10 minutes, stirring occasionally. Drain and reserve.In a large skillet, over medium heat, heat the olive oil, and add onion, garlic, thyme, and mushrooms.Cook, stirring occasionally, for 5 minutes or until onions are tender.Stir in 2 tablespoons of sherry vinegar, and continue cooking for 1 minute. Add chicken stock, and bring it to a boil.Stir in farro, and return to a boil.Lower the heat to a simmer, and cover with a tight fitting lid.  Cook for 10 minutes. Add asparagus, and cook, covered, for an additional 10 minutes.Season with 1 tablespoon sherry vinegar, salt and pepper.', 'servings': 4, 'url': 'https://www.foodista.com/recipe/DMV5G8FD/farro-with-mushrooms-and-asparagus', 'cuisine': '', 'diets': ['dairy free', 'lacto ovo vegetarian'], 'ingredients': [{'id': 's_11011', 'name': 'asparagus', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch asparagus, cut into ¼ pieces'}, {'id': 's_6172', 'name': 'chicken stock', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups chicken stock'}, {'id': 's_10011268', 'name': 'porcini mushrooms', 'quantity': 1.0, 'unit': 'ounce', 'raw': '1 ounce dried porcini mushrooms'}, {'id': 's_10020005', 'name': 'farro', 'quantity': 8.0, 'unit': 'ounces', 'raw': '8 ounces farro'}, {'id': 's_1012049', 'name': 'thyme', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon chopped fresh thyme'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 2.0, 'unit': 'cloves', 'raw': '2 cloves of garlic, finely chopped'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons olive oil'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium onion, chopped'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 4.0, 'unit': 'servings', 'raw': 'Salt and pepper, to taste'}, {'id': 's_1012068', 'name': 'sherry vinegar', 'quantity': 3.0, 'unit': 'tablespoons', 'raw': '3 tablespoons sherry vinegar'}]}, {'id': 's_636589', 'title': 'Butternut Squash Frittata', 'instructions': 'Preheat oven to 350Spray a 10 oz oven safe dish with cooking spray Add your butternut squash In a measuring cup add your eggs and milk. Mix until combined. Pour over butternut squash. Sprinkle with pepper and top with cheese. Bake in oven for 30-35 minutes, until middle is slightly firm Let it cool for a few minutes', 'servings': 1, 'url': 'https://www.foodista.com/recipe/XQXFKGHT/butternut-squash-frittata', 'cuisine': '', 'diets': ['gluten free'], 'ingredients': [{'id': 's_11485', 'name': 'butternut squash', 'quantity': 1.0, 'unit': 'large', 'raw': '1 large butternut squash, peeled, seeded, thinly sliced (with a mandoline)'}, {'id': 's_1159', 'name': 'goat cheese', 'quantity': 0.5, 'unit': 'oz', 'raw': '1/2 oz goat cheese'}, {'id': 's_1226', 'name': 'liquid egg substitute', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup liquid egg substitute'}, {'id': 's_1085', 'name': 'non-fat milk', 'quantity': 2.0, 'unit': 'tbsp', 'raw': '2 tbsp. non-fat milk'}, {'id': 's_10211821', 'name': 'bell pepper', 'quantity': 1.0, 'unit': 'serving', 'raw': 'Pepper to taste'}]}, {'id': 's_646738', 'title': "Herbivoracious' White Bean and Kale Soup", 'instructions': 'PRESSURE COOKER METHOD In the pressure cooker base, but without pressure, heat the olive oil over medium-high heat. Saut the onion, garlic, carrot, and 1 teaspoon salt until the onion is translucent, about 4 minutes. Add the bay leaves, rosemary, and your choice(s) of the Parmesan rind, dried porcini, or broth powder. Add the dry beans and water. Bring up to high pressure and cook for 40 minutes, then allow the pressure to release naturally. Open the lid. Remove the bay leaves and Parmesan rind, if using. Add the kale and lemon juice and simmer for 10 minutes, until the kale is tender. Taste and adjust the seasoning, then serve, garnished with a generous drizzle of extra-virgin olive oil. STOVETOP METHOD Cover the beans with several inches of water and soak overnight. Drain the beans and place in a large saucepan. Cover with water by at least 2 inches and bring to a boil. Reduce the heat and simmer the beans until tender, about 1 1/2 to 2 hours. Drain the beans, reserving the bean broth. In a large saucepan, heat the olive oil over medium-high heat. Saut the onion, garlic, carrot, and 1 teaspoon salt until the onion is translucent, about 4 minutes. Add 4 cups of the bean broth, the bay leaves, rosemary, and your choice of the Parmesan rind, dried porcini, or broth powder. Bring to a simmer and cook for 30 minutes. Remove the bay leaves and Parmesan rind, if using. Add the beans, kale, and lemon juice and simmer for 10 minutes, until the kale is tender. Taste and adjust the seasoning, then serve, garnished with a generous drizzle of extra-virgin olive oil.', 'servings': 6, 'url': 'https://www.foodista.com/recipe/YX5XP75N/herbivoracious-white-bean-and-kale-soup', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_1034053', 'name': 'olive oil', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup extra-virgin olive oil, plus additional for garnish'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium onion, finely diced'}, {'id': 's_10211215', 'name': 'garlic', 'quantity': 1.0, 'unit': 'head', 'raw': '1 whole head garlic, peeled and minced'}, {'id': 's_11124', 'name': 'carrot', 'quantity': 1.0, 'unit': '', 'raw': '1 carrot, finely diced'}, {'id': 's_1082047', 'name': 'kosher salt', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon kosher salt'}, {'id': 's_2004', 'name': 'bay leaves', 'quantity': 2.0, 'unit': '', 'raw': '2 bay leaves'}, {'id': 's_2063', 'name': 'rosemary leaves', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon minced fresh rosemary leaves'}, {'id': 's_10011268', 'name': 'the following: parmesan rind)', 'quantity': 1.0, 'unit': '', 'raw': '1 or more of the following: 1 Parmesan rind or 3/4 ounce dried porcini mushrooms or 2 tablespoons vegetable broth powder (gluten-free if needed)'}, {'id': 's_10316049', 'name': 'navy', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups dried white beans such as cannellini or navy, rinsed and picked over'}, {'id': 's_14412', 'name': 'water', 'quantity': 7.0, 'unit': 'cups', 'raw': '7 cups water'}, {'id': 's_11233', 'name': 'dinosaur kale', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch dinosaur (lacinato) kale, stems stripped and discarded, leaves cut into ribbons and thoroughly washed'}, {'id': 's_9152', 'name': 'juice of lemon', 'quantity': 1.0, 'unit': '', 'raw': 'Juice of 1 lemon'}]}, {'id': 's_663559', 'title': 'Tomato and lentil soup', 'instructions': 'Saut onion and garlic in olive oil for 5 minutes. Add the carrot, saut for another 2 minutes. Add tomatoes, bay leaf and water, stir and bring to the boil. Stir in lentils, season with salt and cook for 5 minutes. Before serving sprinkle with chopped parsley.', 'servings': 4, 'url': 'https://www.foodista.com/recipe/5V4PTMT2/tomato-and-lentil-soup', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tbs', 'raw': '2 Tbs olive oil'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': '', 'raw': '1 onion, chopped'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 2.0, 'unit': 'cloves', 'raw': '2 cloves garlic, minced'}, {'id': 's_11124', 'name': 'carrots', 'quantity': 3.0, 'unit': '', 'raw': '3 carrots cut into cubes'}, {'id': 's_11531', 'name': 'tomatoes', 'quantity': 480.0, 'unit': 'g', 'raw': '480g canned chopped tomatoes'}, {'id': 's_2004', 'name': 'bay leaf', 'quantity': 1.0, 'unit': '', 'raw': '1 bay leaf'}, {'id': 's_14412', 'name': 'water', 'quantity': 1.3, 'unit': 'l', 'raw': '1.3 l water'}, {'id': 's_10316069', 'name': 'lentils', 'quantity': 250.0, 'unit': 'g', 'raw': '250 g lentils'}, {'id': 's_2047', 'name': 'salt', 'quantity': 0.25, 'unit': 'tsp', 'raw': '¼ tsp salt'}, {'id': 's_11297', 'name': 'parsley', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch chopped parsley'}]}, {'id': 's_662670', 'title': 'Swiss Chard Wraps', 'instructions': 'Chop off the stems of the swiss chard at the point where it meets the leaf. You could stem the swiss chard entirely. I like leaving a bit of stem with the leaves to give better structure to the wraps. Chop the cauliflower into small pieces and pulse them in a food processor until it looks like rice. I usually pulse the cauliflower florets and the stalk together. Place the olive oil in a saut pan over medium-high heat. Once the pan is hot, add the garlic and let it fry for about a minute or two, or until the garlic starts to brown. Add the pulsed cauliflower rice and cook it for about 2-3 minutes. The cauliflower should turn into a vibrant yellow-orange color when it is cooked. Add a pinch of salt and chopped basil to the cauliflower and stir. Spiralize the zucchini with Blade B to create zucchini noodles. If you do not have a spiralizer, just create zucchini ribbons with a vegetable peeler. To assemble the wraps, place a large leaf flat down. Add a bit of sauted cauliflower, zucchini noodles, red pepper, and avocado along the swiss chard stalk. Drizzle a bit of vinaigrette on top of the vegetables and wrap everything up. Enjoy these wraps as a side to your favorite protein! Feel free to dip these wraps in more sauce. These wraps are best consumed when they are freshly made. Refrigerate any leftovers in an airtight container.', 'servings': 6, 'url': 'https://www.foodista.com/recipe/LHXZRNVW/swiss-chard-wraps', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'vegan'], 'ingredients': [{'id': 's_11147', 'name': 'swiss chard leaves', 'quantity': 6.0, 'unit': 'large', 'raw': '6-7 large swiss chard leaves, rinsed and dried'}, {'id': 's_9200', 'name': 'orange cauliflower', 'quantity': 1.0, 'unit': 'small head', 'raw': '1 small head of orange cauliflower'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.5, 'unit': 'tbs', 'raw': '1 1/2 Tbs olive oil'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 3.0, 'unit': 'cloves', 'raw': '3 cloves garlic, pressed or minced'}, {'id': 's_2047', 'name': 'salt', 'quantity': 1.0, 'unit': 'pinch', 'raw': 'pinch of salt'}, {'id': 's_2044', 'name': 'basil', 'quantity': 1.0, 'unit': 'sprig', 'raw': '1 sprig of fresh basil, leaves finely chopped'}, {'id': 's_11477', 'name': 'zucchini', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium zucchini (courgette)'}, {'id': 's_11821', 'name': 'bell pepper', 'quantity': 1.0, 'unit': 'large', 'raw': '1 large red pepper, thinly sliced'}, {'id': 's_9037', 'name': 'avocado', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium avocado, sliced'}, {'id': 's_16091', 'name': "trader joe's spicy peanut vinaigrette", 'quantity': 3.0, 'unit': 'tbs', 'raw': "3-4 Tbs Trader Joe's Asian Style Spicy Peanut Vinaigrette (or your favorite sauce)"}]}, {'id': 's_640062', 'title': 'Corn Avocado Salsa', 'instructions': 'Preheat oven to 375 degrees. Spread corn flat on a baking sheet.Spray lightly with olive oil spray.Roast corn in the oven for about 8-10 minutes. (Be careful not to brown too much or burn.) Remove from heat and allow to cool.Finely chop red pepper and garlic and mix in a bowl.Peel and coarsely chop avocado and add to bowl. Add cooled corn. Mix in cumin and vinegar and blend well.', 'servings': 2, 'url': 'https://www.foodista.com/recipe/BDRS2JZG/corn-avocado-salsa', 'cuisine': 'mexican', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_9037', 'name': 'avocado', 'quantity': 1.0, 'unit': '', 'raw': '1 Avocado'}, {'id': 's_2069', 'name': 'balsamic vinegar', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon Balsamic vinegar'}, {'id': 's_1002014', 'name': 'cumin', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon Cumin'}, {'id': 's_11913', 'name': 'corn', 'quantity': 0.75, 'unit': 'cup', 'raw': '3/4 cup Corn, freshly hulled (You can also use frozen corn, thawed)'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 1.0, 'unit': 'clove', 'raw': '1 clove garlic'}, {'id': 's_11821', 'name': 'bell pepper', 'quantity': 0.5, 'unit': 'medium', 'raw': '1/2 medium Red Pepper'}]}, {'id': 's_715421', 'title': 'Cheesy Chicken Enchilada Quinoa Casserole', 'instructions': "To get started, heat your oven to 350 and prepare an 8x8 baking dish. Cook the quinoa according to the instructions. If you haven't already, boil and shred your chicken breast.In a medium sized mixing bowl add 2 Tbsp cilantro, 1 cup shredded cheese, quinoa, tomatoes with chilis, black beans, half of the can of sweet corn, verde enchilada sauce, cumin, chili powder, white pepper, black pepper, and salt to taste. Mix everything well, and then pour into the 8 x8 baking dish. Cover with the last cup of cheese and then bake in the oven for 15 minutes. Remove from oven and allow to cool for 5 minutes. Then top with chopped Roma tomato, chopped avocado, green onion tops, and remaining 2 tsp of cilantro. Serve immediately.", 'servings': 4, 'url': 'https://www.pinkwhen.com/cheesy-chicken-enchilada-quinoa-casserole/', 'cuisine': 'mexican', 'diets': ['gluten free'], 'ingredients': [{'id': 's_9037', 'name': 'avocado', 'quantity': 1.0, 'unit': 'small', 'raw': '1 small Avocado (chopped)'}, {'id': 's_1002030', 'name': 'pepper', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp black pepper'}, {'id': 's_16018', 'name': 'black beans', 'quantity': 15.0, 'unit': 'oz', 'raw': '1 (15oz) can of black beans (I like the low sodium version)'}, {'id': 's_10011693', 'name': 'canned tomatoes', 'quantity': 10.0, 'unit': 'oz', 'raw': '1 (10oz) can of tomatoes with green chilis'}, {'id': 's_2009', 'name': 'chili powder', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp chili powder'}, {'id': 's_20137', 'name': 'quinoa', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup cooked quinoa'}, {'id': 's_1002014', 'name': 'cumin', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp cumin'}, {'id': 's_6599', 'name': 'verde enchilada sauce', 'quantity': 10.0, 'unit': 'oz', 'raw': '1 (10oz) can of verde enchilada sauce'}, {'id': 's_11165', 'name': 'cilantro', 'quantity': 2.0, 'unit': 'tbsp', 'raw': 'fresh cilantro (2Tbsp and 2 tsp separated)'}, {'id': 's_11291', 'name': 'green onion tops', 'quantity': 4.0, 'unit': 'servings', 'raw': 'green onion tops (chopped)'}, {'id': 's_10211529', 'name': 'roma tomato', 'quantity': 1.0, 'unit': '', 'raw': '1 Roma tomato (chopped)'}, {'id': 's_2047', 'name': 'salt', 'quantity': 4.0, 'unit': 'servings', 'raw': 'salt to taste'}, {'id': 's_1011026', 'name': 'cheese', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups of shredded cheese (my favorite is the Kraft Mexican 4 cheese blend and one bag equals two cups!)'}, {'id': 's_1055062', 'name': 'chicken breast', 'quantity': 1.0, 'unit': '', 'raw': '1 boneless skinless chicken breast (boiled and shredded)'}, {'id': 's_10111168', 'name': 'corn', 'quantity': 15.0, 'unit': 'oz', 'raw': '1 (15oz) can of sweet corn (you are only going to use half of the can)'}, {'id': 's_2032', 'name': 'pepper', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp white pepper'}]}, {'id': 's_715957', 'title': 'Zesty Green Pea and Jalapeño Pesto Pasta', 'instructions': 'Soak the sun-dried tomatoes in hot water for 20 to 30 minutes. Drain and chop.Cook the pasta in a large saucepan of boiling salted water according to package directions. Two minutes before the pasta is finished cooking, toss in the remaining peas.In a small food processor, process the sun-dried tomatoes, 1/4 cup of the peas, basil, mint, shallot or onion, garlic, jalapeo, lemon juice and zest, salt and pepper with 3 tablespoons of olive oil in a small food processor. Process until smooth. Add another tablespoon of olive oil if the pesto is too thick to process. Drain the pasta and peas and toss with the pesto. Serve hot or warm, or cold as a salad.', 'servings': 4, 'url': 'https://www.foodandspice.com/2014/09/zesty-green-pea-and-jalapeno-pesto-pasta.html', 'cuisine': '', 'diets': ['dairy free'], 'ingredients': [{'id': 's_2044', 'name': 'fresh basil leaves', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup fresh basil leaves'}, {'id': 's_2064', 'name': 'fresh mint leaves', 'quantity': 0.75, 'unit': 'cup', 'raw': '3/4 cup fresh mint leaves'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 2.0, 'unit': 'cloves', 'raw': '2 cloves garlic, chopped'}, {'id': 's_11979', 'name': 'jalapeno', 'quantity': 1.0, 'unit': '', 'raw': '1 jalapeño, seeded and chopped'}, {'id': 's_9152', 'name': 'juice of lemon', 'quantity': 1.0, 'unit': '', 'raw': 'juice and zest from 1 lemon'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 3.0, 'unit': 'tablespoons', 'raw': '3 tablespoons olive oil'}, {'id': 's_11304', 'name': 'peas', 'quantity': 1.25, 'unit': 'cups', 'raw': '1 1/4 cups fresh garden peas or defrosted frozen green peas'}, {'id': 's_11320420', 'name': 'rotini pasta', 'quantity': 3.0, 'unit': 'cups', 'raw': '3 cups dried fusilli or rotini pasta'}, {'id': 's_1012047', 'name': 'sea salt', 'quantity': 1.0, 'unit': 'pinch', 'raw': 'pinch of sea salt'}, {'id': 's_10011282', 'name': 'red onion', 'quantity': 1.0, 'unit': 'small', 'raw': '1 shallot or small red onion, chopped'}, {'id': 's_11955', 'name': 'sun-dried tomatoes', 'quantity': 4.0, 'unit': '', 'raw': '4 sun-dried tomatoes'}, {'id': 's_-1', 'name': 'ground', 'quantity': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon fresh ground black, green or white pepper'}]}, {'id': 's_648320', 'title': 'Jade Buddha Salmon Tartare', 'instructions': 'Combine all ingredients except lime juice and vinegar. Chill for 30 minutes. Add lime juice and vinegar, adjust to perfect, and serve.', 'servings': 2, 'url': 'https://www.foodista.com/recipe/7J3VXBX3/jade-buddha-salmon-tartare', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'primal', 'pescatarian'], 'ingredients': [{'id': 's_15076', 'name': 'salmon', 'quantity': 12.0, 'unit': 'ounces', 'raw': '12 ounces salmon, finely diced'}, {'id': 's_11291', 'name': 'green onion', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons chopped green onion'}, {'id': 's_11156', 'name': 'chives', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon chopped chives'}, {'id': 's_11165', 'name': 'cilantro', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon cilantro'}, {'id': 's_1012044', 'name': 'thai basil', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon thai basil'}, {'id': 's_11216', 'name': 'ginger', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons grated ginger'}, {'id': 's_1009159', 'name': 'lime zest', 'quantity': 1.0, 'unit': '', 'raw': 'zest of 1 lime'}, {'id': 's_9160', 'name': 'lime juice', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': 'good tablespoon of lime juice'}, {'id': 's_1022053', 'name': 'rice vinegar', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon champagne or rice vinegar'}, {'id': 's_10011819', 'name': 'habanero sauce and chile', 'quantity': 2.0, 'unit': 'servings', 'raw': 'habanero sauce and minced green chile'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 2.0, 'unit': 'servings', 'raw': 'salt and pepper'}, {'id': 's_4053', 'name': 'olive oil to coat', 'quantity': 2.0, 'unit': 'servings', 'raw': 'olive oil to coat'}]}, {'id': 's_716432', 'title': 'Finger Foods: Frittata Muffins', 'instructions': '', 'servings': 1, 'url': 'https://fullbellysisters.blogspot.com/2014/05/finger-foods-frittata-muffins.html', 'cuisine': '', 'diets': ['gluten free', 'lacto ovo vegetarian', 'primal', 'ketogenic'], 'ingredients': [{'id': 's_11090', 'name': 'broccoli', 'quantity': 0.75, 'unit': 'cup', 'raw': '3/4 cup chopped, cooked broccoli'}, {'id': 's_11156', 'name': 'chives', 'quantity': 2.0, 'unit': 't', 'raw': '2 T chopped chives'}, {'id': 's_1011077', 'name': 't cream', 'quantity': 1.0, 'unit': '', 'raw': '1 + 2 T cream or whole milk'}, {'id': 's_1123', 'name': 'eggs', 'quantity': 6.0, 'unit': '', 'raw': '6 eggs'}, {'id': 's_10011821', 'name': 'orange pepper', 'quantity': 0.33333334, 'unit': 'cup', 'raw': '1/3 cup minced orange pepper'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 1.0, 'unit': 'serving', 'raw': 'salt and pepper'}, {'id': 's_1001009', 'name': 'cheddar cheese', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup shredded cheddar cheese'}, {'id': 's_11529', 'name': 'tomato', 'quantity': 0.33333334, 'unit': 'cup', 'raw': '1/3 cup seeded, chopped tomato'}]}, {'id': 's_798400', 'title': 'Spicy Black-Eyed Pea Curry with Swiss Chard and Roasted Eggplant', 'instructions': 'Rinse the black-eyed peas and soak in several inches of water for 6 hours or overnight. Drain and rinse, then transfer to a large saucepan and cover with fresh water. Bring to a boil, reduce heat to medium-low, cover, and simmer for 40 to 60 minutes. Take care not to overcook  the beans should be tender but not be falling apart. Drain and set aside.To prepare the eggplant, cut of the stem and bottom edge and then cut in half lengthwise. Score the flesh into diagonal 1-inch lines, then turn and score again until you have a diagonal pattern. Take care not to cut through the skin. Sprinkle with some salt and let sit for 40 minutes. Rinse and squeeze out any excess water. Brush the eggplant with some oil and transfer to a roasting pan. Bake in a preheated 400 oven until the flesh appears collapsed and is wrinkly. Remove from heat and let cool for about 10 minutes, season with a bit of salt, and remove the flesh from the eggplant. If there is too much water, drain in a strainer. Set aside. Heat the oil over medium heat in the same saucepan used to cook the black-eyed peas. When hot, toss in the shallots and chilies and saut for 2 to 3 minutes. Now add the spices and stir for another minute, until fragrant. Add the tomato, cook for another few minutes, and then add the eggplant and black-eyed peas, and cook for another few minutes, stirring often. Pour a few tablespoons of water into the pan and add handfuls of chard at a time until wilted. Add more water as necessary. Add the lemon juice and salt to taste near the end of the cooking time. Remove from heat, cover, and let sit for a few minutes before serving.', 'servings': 6, 'url': 'https://www.foodandspice.com/2016/08/spicy-black-eyed-pea-curry-with-swiss.html', 'cuisine': 'indian', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_16063', 'name': 'black-eyed peas', 'quantity': 2.0, 'unit': 'cups', 'raw': '2/3 cup dried black-eyed peas (2 cups cooked)'}, {'id': 's_2015', 'name': 'curry powder', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons curry powder'}, {'id': 's_93663', 'name': 'garam masala', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon garam masala'}, {'id': 's_11209', 'name': 'globe', 'quantity': 1.0, 'unit': 'large', 'raw': '1 large globe or Italian eggplant'}, {'id': 's_1002013', 'name': 'ground coriander', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon ground coriander'}, {'id': 's_1012014', 'name': 'ground cumin', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon ground cumin'}, {'id': 's_1002024', 'name': 'ground mustard powder', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon ground mustard powder'}, {'id': 's_9152', 'name': 'juice of lemon', 'quantity': 3.0, 'unit': '', 'raw': 'juice from 1 lemon (3 tablespoons)'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons olive oil'}, {'id': 's_31015', 'name': 'chilies', 'quantity': 2.0, 'unit': '', 'raw': '2 green or red chilies, seeded and finely chopped'}, {'id': 's_1012047', 'name': 'sea salt', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon sea salt, or to taste'}, {'id': 's_11677', 'name': 'shallots', 'quantity': 2.0, 'unit': '', 'raw': '2 shallots, mined'}, {'id': 's_11147', 'name': 'swiss chard', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch Swiss chard, trimmed and chopped'}, {'id': 's_11529', 'name': 'tomato', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium tomato, finely chopped'}, {'id': 's_14412', 'name': 'water', 'quantity': 5.0, 'unit': 'tablespoons', 'raw': '5 tablespoons water, or more as needed'}]}, {'id': 's_652417', 'title': 'Moroccan chickpea and lentil stew', 'instructions': 'Heat oil in large saucepan over medium-high heat, add onion and cook for about 3 minutes. Add celery, carrot and broccoli to pan and saut for about 5 minutes. Add in all seasonings and cook additional 1 minute. Add water, tomato paste, chickpeas and lentils, bring to a boil. Cover, reduce heat to low and simmer for 20 minutes.Meanwhile, cook couscous in separate pan according to package directions. Add cilantro and lemon juice to stew and serve over warm couscous.', 'servings': 3, 'url': 'https://www.foodista.com/recipe/C6DXLHJH/moroccan-chickpea-and-lentil-stew', 'cuisine': '', 'diets': ['dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_11090', 'name': 'broccoli', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup broccoli'}, {'id': 's_16058', 'name': 'chickpeas', 'quantity': 1.0, 'unit': 'can', 'raw': '1 can chickpeas, rinsed and drained'}, {'id': 's_11124', 'name': 'carrots', 'quantity': 2.0, 'unit': 'large', 'raw': '2 large carrots, chopped'}, {'id': 's_10111143', 'name': 'celery stalks', 'quantity': 2.0, 'unit': '', 'raw': '2 celery stalks, chopped ili 1/3 cup chopped celery root'}, {'id': 's_16070', 'name': 'lentils', 'quantity': 0.5, 'unit': 'cup', 'raw': '½ cup cooked lentils'}, {'id': 's_20028', 'name': 'couscous', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup couscous'}, {'id': 's_11165', 'name': 'cilantro', 'quantity': 3.0, 'unit': 'servings', 'raw': 'Fresh cilantro, optional'}, {'id': 's_1012010', 'name': 'ground cinnamon', 'quantity': 0.125, 'unit': 'tsp', 'raw': '⅛ tsp ground cinnamon'}, {'id': 's_1012014', 'name': 'ground cumin', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp ground cumin'}, {'id': 's_2043', 'name': 'ground turmeric', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp ground turmeric'}, {'id': 's_9152', 'name': 'lemon juice', 'quantity': 1.0, 'unit': 'tbs', 'raw': '1 Tbs lemon juice'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp olive oil'}, {'id': 's_2028', 'name': 'paprika', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp paprika'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 3.0, 'unit': 'servings', 'raw': 'Salt and pepper'}, {'id': 's_11887', 'name': 'tomato paste', 'quantity': 2.0, 'unit': 'tbs', 'raw': '2-3 Tbs tomato paste'}, {'id': 's_14412', 'name': 'water', 'quantity': 1.5, 'unit': 'cups', 'raw': '1 ½ cups water'}]}, {'id': 's_661925', 'title': 'Strawberry-Mango Quinoa Salad', 'instructions': 'Prepare the quinoa: In a medium saucepan combine the quinoa, water and 1/4 t. salt. Bring to a boil, reduce heat to low, cover and simmer until the liquid is just absorbed, about 15 minutes. Spread the cooked quinoa out on a baking sheet to cool for about 20 minutes.In a large bowl whisk together lime juice, zest, honey, sour cream and olive oil. Add the cooled quinoa, strawberries, mango, cucumber and mint. Toss well to combine and season with salt &amp; pepper. Serve immediately.', 'servings': 4, 'url': 'https://www.foodista.com/recipe/K2BYJP76/strawberry-mango-quinoa-salad', 'cuisine': '', 'diets': ['gluten free', 'lacto ovo vegetarian'], 'ingredients': [{'id': 's_11206', 'name': 'cucumber', 'quantity': 0.75, 'unit': 'cup', 'raw': '3/4 cup cucumber'}, {'id': 's_2064', 'name': 'mint', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons chopped fresh mint'}, {'id': 's_19296', 'name': 'honey', 'quantity': 1.0, 'unit': 't', 'raw': '1 T. honey'}, {'id': 's_9160', 'name': 'lime juice', 'quantity': 2.0, 'unit': 't', 'raw': '2 T. lime juice'}, {'id': 's_1009159', 'name': 'lime zest', 'quantity': 0.5, 'unit': 't', 'raw': '1/2 t. lime zest'}, {'id': 's_9176', 'name': 'mango', 'quantity': 0.5, 'unit': '', 'raw': '1/2 mango'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 0.25, 'unit': 'c', 'raw': '1/4 c. olive oil'}, {'id': 's_10211821', 'name': 'bell pepper', 'quantity': 4.0, 'unit': 'servings', 'raw': 'pepper'}, {'id': 's_20035', 'name': 'quinoa', 'quantity': 1.0, 'unit': 'c', 'raw': '1 c. quinoa, well rinsed'}, {'id': 's_2047', 'name': 'salt', 'quantity': 4.0, 'unit': 'servings', 'raw': 'salt'}, {'id': 's_1001116', 'name': 'cream', 'quantity': 1.0, 'unit': 't', 'raw': '1 T. sour cream (or plain yogurt can be subbed)'}, {'id': 's_9316', 'name': 'strawberries', 'quantity': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups strawberries, hulled and quartered'}, {'id': 's_14412', 'name': 'water', 'quantity': 1.5, 'unit': 'c', 'raw': '1 1/2 c. water'}]}, {'id': 's_636787', 'title': 'Caldo Verde - Portuguese Kale Soup', 'instructions': "Chop your onions, slice your carrots and smash your garlic. Set aside. Peel and chop the potatoes. Set aside in a bowl of cold water. Remove the casing from your chorizo. This is an important step. Chorizo casing is tough and unforgiving and will make the sausage link curl during the cooking process. Just remove it and don't worry about appearance. Cut the links length-wise then chop into half-moons. Sautee in a separate pan until the are nice and browned. Don't put into the pot until the last minute, otherwise the color of the chorizo will leach into the soup turning it a weird red color. Now it's time to prepare the kale. With each individual leaf, cut out the stem. You can do this several ways. Cut a triangle out of the leaf, or fold over the leaf and cut out the stem that way. Or rip off the halves of the leaves off the stem. I like a little bit of stem to give some crunch and texture. Tightly roll the leaf into a bundle. Run your knife over it to julienne the leaf into thin strips. Don't worry if it's not perfect. Set aside the kale. In a big pot, sautee your onions, carrots and garlic in a bit of olive oil. Once the vegetables start to soften, add the potatoes and some crushed red pepper flakes. Stir the pot and cook the potatoes until the outer edges start turning clear. Then add the 6 cups of water and 2 bouillion packets (or 4 cups of broth and 2 cups of water) to the pot. Bring to a boil then let simmer until the potatoes are cooked. With a wooden spoon, mash the potatoes against the side of the pot. Do this until almost all the chunks of potatoes are mashed. Leave some chunks behind. This will give your soup a wonderful hearty texture. Now it's time to add the Kale. It looks like a lot and will fill up your whole pot but not to worry because it wilts down pretty quickly. Cook for 5 minutes at a simmer then stir in chorizo sausage. Serve hot or at room temperature (the latter is my favorite). Eat with a nice crusty loaf of Portuguese bread. Enjoy!", 'servings': 4, 'url': 'https://www.foodista.com/recipe/7SDK7CGK/caldo-verde-portuguese-kale-soup', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'whole 30'], 'ingredients': [{'id': 's_11282', 'name': 'onion', 'quantity': 0.5, 'unit': 'large', 'raw': '1/2 large onion chopped'}, {'id': 's_11124', 'name': 'carrots', 'quantity': 3.0, 'unit': '', 'raw': '3 carrots peeled and sliced'}, {'id': 's_10211215', 'name': 'garlic cloves', 'quantity': 3.0, 'unit': '', 'raw': '3 garlic cloves smashed'}, {'id': 's_11352', 'name': 'potatoes', 'quantity': 4.0, 'unit': 'large', 'raw': '4 large yellow potatoes chopped'}, {'id': 's_99231', 'name': 'chorizo links', 'quantity': 2.0, 'unit': '', 'raw': '2 chorizo links with casings removed, halved and chopped'}, {'id': 's_6172', 'name': 'chicken stock and 2 cups of water', 'quantity': 4.0, 'unit': 'cups', 'raw': '4 cups of chicken stock and 2 cups of water'}, {'id': 's_11233', 'name': 'kale', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch of kale julienned'}, {'id': 's_14412', 'name': 'of water and 2 packets of chicken boullion', 'quantity': 1.0, 'unit': 'cup', 'raw': 'cup or 6 of water and 2 packets of Chicken Boullion'}, {'id': 's_1032009', 'name': 'pepper flakes', 'quantity': 4.0, 'unit': 'servings', 'raw': 'crushed red pepper flakes'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 4.0, 'unit': 'servings', 'raw': 'salt and pepper to taste'}]}, {'id': 's_652423', 'title': 'Moroccan Couscous and Chickpea Salad', 'instructions': 'Heat broth and a teaspoon of salt and bring to a boil. Place couscous in a bowl and add broth.  Cover bowl to let couscous absorb liquid.After  5 minutes, remove cover and fluff couscous with a fork.In a large bowl, add the chickpeas, pistachios, red peppers, green onions and parsley and mix well. Add the zest and juice of the lemon and mix again. Add the spice mixture over the couscous and mix well. Taste, and add salt if needed. Let the salad marinate for an hour or so before serving.', 'servings': 6, 'url': 'https://www.foodista.com/recipe/CCZR4V77/moroccan-couscous-and-chickpea-salad', 'cuisine': '', 'diets': ['dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_1002030', 'name': 'pepper', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon black pepper'}, {'id': 's_16058', 'name': 'chickpeas', 'quantity': 15.0, 'unit': 'ounce', 'raw': '15 ounce can of chickpeas (garbanzo beans), rinsed and strained'}, {'id': 's_2031', 'name': 'cayenne', 'quantity': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon cayenne'}, {'id': 's_2010', 'name': 'cinnamon', 'quantity': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon cinnamon'}, {'id': 's_20028', 'name': 'couscous', 'quantity': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups couscous'}, {'id': 's_11291', 'name': 'green onions', 'quantity': 3.0, 'unit': '', 'raw': '3 chopped green onions or scallions'}, {'id': 's_2021', 'name': 'ground ginger', 'quantity': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon ground ginger'}, {'id': 's_2025', 'name': 'ground nutmeg', 'quantity': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon ground nutmeg'}, {'id': 's_9150', 'name': 'lemon', 'quantity': 1.0, 'unit': '', 'raw': '1 lemon'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 6.0, 'unit': 'servings', 'raw': 'Olive oil'}, {'id': 's_11297', 'name': 'parsley', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup chopped parsley'}, {'id': 's_12151', 'name': 'pistachio nuts', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup shelled and unsalted pistachio nuts'}, {'id': 's_10211821', 'name': 'bell pepper', 'quantity': 1.0, 'unit': 'small', 'raw': '1 small red pepper, diced'}, {'id': 's_2047', 'name': 'salt', 'quantity': 6.0, 'unit': 'servings', 'raw': 'Salt to taste'}, {'id': 's_2043', 'name': 'turmeric', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon turmeric'}, {'id': 's_6615', 'name': 'vegetable broth', 'quantity': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups vegetable broth'}]}, {'id': 's_715447', 'title': 'Easy Vegetable Beef Soup', 'instructions': 'To get started, bring 4 quarts of water to a boil in a large pot. While waiting on the water to boil, cut the beef short ribs into bite-sized pieces and add them to the water. Add in diced tomatoes, potatoes, diced onion, parsley, garlic powder, beef bouillon cubes, Italian seasoning, salt, pepper, Worcestershire sauce, celery salt, bay leaves, and stir. Then add carrots, celery, black-eyed peas, butter beans, corn, and macaroni. Heat on high, stirring occasionally until the stew mixture comes to a boil. Once you have reached a boil, cover with a lid, lower heat enough to keep it simmering.\xa0 Continue to simmer for 1.5 to 2 hours, stirring occasionally.', 'servings': 8, 'url': 'https://www.pinkwhen.com/vegetable-beef-stew-recipe/', 'cuisine': '', 'diets': ['dairy free'], 'ingredients': [{'id': 's_13149', 'name': 'beef short ribs', 'quantity': 3.0, 'unit': 'lbs', 'raw': '3 lbs of boneless beef short ribs'}, {'id': 's_10120499', 'name': 'elbow macaroni', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup uncooked elbow macaroni'}, {'id': 's_14412', 'name': 'water 4 qts', 'quantity': 16.0, 'unit': 'cups', 'raw': '16 cups of water 4 Qts'}, {'id': 's_10011693', 'name': 'canned tomatoes', 'quantity': 28.0, 'unit': 'oz', 'raw': '1 28oz can diced tomatoes'}, {'id': 's_11352', 'name': 'potatoes', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup of small diced potatoes'}, {'id': 's_11124', 'name': 'on carrots', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup on thin sliced carrots'}, {'id': 's_11143', 'name': 'celery', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup thin sliced celery'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups chopped onion'}, {'id': 's_11168', 'name': 'kernal corn', 'quantity': 15.0, 'unit': 'oz', 'raw': '1 15oz kernal corn (uncooked)'}, {'id': 's_10016073', 'name': 'butter beans', 'quantity': 15.0, 'unit': 'oz', 'raw': '1 15oz can butter beans'}, {'id': 's_10016063', 'name': 'eyed peas', 'quantity': 15.0, 'unit': 'oz', 'raw': '1 15oz can black – eyed peas'}, {'id': 's_2004', 'name': 'bay leaves', 'quantity': 2.0, 'unit': '', 'raw': '2 bay leaves'}, {'id': 's_1022020', 'name': 'garlic powder', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp garlic powder'}, {'id': 's_1052047', 'name': 'celery salt', 'quantity': 1.0, 'unit': 'tsp', 'raw': '1 tsp celery salt'}, {'id': 's_6971', 'name': 'worcestershire sauce', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp Worcestershire sauce'}, {'id': 's_2047', 'name': 'salt', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp salt'}, {'id': 's_1002030', 'name': 'ground pepper', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp fresh ground pepper'}, {'id': 's_1022027', 'name': 'seasoning', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp Italian seasoning'}, {'id': 's_6076', 'name': 'beef bouillon cubes', 'quantity': 2.0, 'unit': '', 'raw': '2 beef bouillon cubes'}, {'id': 's_2029', 'name': 'parsley', 'quantity': 2.0, 'unit': 'tbsp', 'raw': '2 Tbsp dried parsley or fresh parsley'}]}, {'id': 's_716311', 'title': 'Mango Fried Rice', 'instructions': 'Wash your rice and bring to boil on medium heat with very little water as you are still going to cook it in chicken stock.Once the rice is slightly soft and the initial water has dried up, reduce the heat and pour in the chicken stock and cook till the chicken stock is all absorbed and has dried up. The chicken stock if freshly made will have some oil from the chicken so your rice does not need oil.Increase the heat and stir in the chopped vegetables and pepper. Add your seasoning cube.Finally stir in your cubed mango and serve warm with any protein of your choice. I’d say chicken but it’s up to you.', 'servings': 2, 'url': 'https://www.afrolems.com/2015/05/02/mango-fried-rice/', 'cuisine': 'chinese', 'diets': ['gluten free', 'dairy free'], 'ingredients': [{'id': 's_6172', 'name': 'chicken stock', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups of chicken stock'}, {'id': 's_99186', 'name': 'seasoning cubes', 'quantity': 2.0, 'unit': 'servings', 'raw': 'Seasoning cubes'}, {'id': 's_9176', 'name': 'mango', 'quantity': 3.0, 'unit': 'slices', 'raw': '3 slices of mango cubed'}, {'id': 's_20444', 'name': 'rice', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup of rice'}, {'id': 's_11583', 'name': 'vegetables', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup of chopped vegetables'}, {'id': 's_10011819', 'name': 'scotch bonnet pepper', 'quantity': 1.0, 'unit': '', 'raw': '1 scotch bonnet pepper'}]}, {'id': 's_157344', 'title': 'Spicy Salad with Kidney Beans, Cheddar, and Nuts', 'instructions': 'Rinse and drain the kidney beans, cut the sundried tomatoes, and tear the slice of cheese into small pieces. Put the mixed greens in a bowl and top with kidney beans, sundried tomatoes, cheddar cheese, and nuts. Mix together the olive oil, balsamic vinegar, and hot sauce in a small bowl. Pour the dressing over the salad. Fast, easy, and healthy-- one of my favorite lunches!', 'servings': 1, 'url': 'http://spoonacular.com/-1384191937003', 'cuisine': '', 'diets': ['gluten free', 'lacto ovo vegetarian'], 'ingredients': [{'id': 's_12061', 'name': 'almonds', 'quantity': 15.0, 'unit': 'grams', 'raw': '15 grams almonds'}, {'id': 's_9037', 'name': 'avocado', 'quantity': 0.5, 'unit': '', 'raw': '1/2 avocado'}, {'id': 's_2069', 'name': 'balsamic vinegar', 'quantity': 5.0, 'unit': 'ml', 'raw': '5 ml balsamic vinegar'}, {'id': 's_1009', 'name': 'cheddar cheese', 'quantity': 30.0, 'unit': 'grams', 'raw': '1/4 cup (30 grams) cheddar cheese'}, {'id': 's_16033', 'name': 'kidney beans', 'quantity': 113.0, 'unit': 'grams', 'raw': '1/2 cup (113 grams) cooked kidney beans'}, {'id': 's_21052', 'name': 'greens', 'quantity': 150.0, 'unit': 'grams', 'raw': '150 grams mixed greens'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 10.0, 'unit': 'ml', 'raw': '10 ml olive oil'}, {'id': 's_12585', 'name': 'roasted cashews', 'quantity': 15.0, 'unit': 'grams', 'raw': '15 grams roasted salted cashews'}, {'id': 's_11955', 'name': 'sundried tomatoes', 'quantity': 2.0, 'unit': '', 'raw': '2-3 sundried tomatoes'}, {'id': 's_1026168', 'name': 'tabasco', 'quantity': 2.0, 'unit': 'dashes', 'raw': '2 dashes (or more if you like it hot!) Tabasco'}]}, {'id': 's_658509', 'title': 'Roasted Broccoli with Lemon and Garlic', 'instructions': 'Preheat the oven to 400 degrees FIn a large bowl, add broccoli florets, olive oil, salt, pepper and garlic. Spread the broccoli out in an even layer on a baking sheet. Bake in the preheated oven until broccoli is tender enough to pierce the stems with a fork, 15 to 20 minutes. Remove and place in a bowl, toss with lemon juice.', 'servings': 4, 'url': 'https://www.foodista.com/recipe/3Z8R4RGY/roasted-broccoli-with-lemon-and-garlic', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'whole 30', 'vegan'], 'ingredients': [{'id': 's_10011090', 'name': 'broccoli florets', 'quantity': 5.0, 'unit': 'cups', 'raw': '5 cups Organic Broccoli Florets'}, {'id': 's_1034053', 'name': 'extra virgin olive oil', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons Extra Virgin Olive Oil'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 1.0, 'unit': 'clove', 'raw': '1 clove of garlic, or more'}, {'id': 's_1002030', 'name': 'ground pepper', 'quantity': 0.5, 'unit': 'teaspoons', 'raw': '½ teaspoons Ground Black Pepper'}, {'id': 's_9152', 'name': 'lemon juice', 'quantity': 0.5, 'unit': 'teaspoons', 'raw': '½ teaspoons Lemon Juice'}, {'id': 's_2047', 'name': 'salt', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon salt'}]}, {'id': 's_716195', 'title': 'Spicy Indian-Style Hummus', 'instructions': 'Rinse the chickpeas and soak for 8 hours or overnight covered in several inches of water with a little yogurt whey or lemon juice added. Drain and rinse, then transfer to a large saucepan.  Cover with several inches of fresh water, bring to a boil, reduce the heat to medium-low and cover.  Simmer for 1 to 1 1/2 hours or until the beans are buttery soft. Drain.In a food processor, combine all of the ingredients and process until you have a thick, smooth paste. You may need to add extra olive oil or a bit of water if you want a thinner paste. Makes 3 cups, nutrition information is based on 1/4 cup serving.', 'servings': 12, 'url': 'https://www.foodandspice.com/2012/07/spicy-hummus-indian-style.html', 'cuisine': 'middle eastern', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_1032035', 'name': 'asafetida', 'quantity': 1.0, 'unit': 'pinch', 'raw': 'pinch of asafetida'}, {'id': 's_2031', 'name': 'cayenne', 'quantity': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon cayenne'}, {'id': 's_16056', 'name': 'chickpeas', 'quantity': 1.25, 'unit': 'cups', 'raw': '1 1/4 cups dried chickpeas'}, {'id': 's_11156', 'name': 'chives', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup fresh chives, chopped'}, {'id': 's_10211216', 'name': 'ginger', 'quantity': 1.0, 'unit': 'inch', 'raw': '1-inch piece fresh ginger, chopped'}, {'id': 's_10511297', 'name': 'parsley', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup fresh parsley or cilantro, chopped'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 2.0, 'unit': 'cloves', 'raw': '2 cloves garlic, chopped'}, {'id': 's_1002013', 'name': 'ground coriander', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon ground coriander'}, {'id': 's_1012014', 'name': 'ground cumin', 'quantity': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon ground cumin'}, {'id': 's_1002030', 'name': 'ground pepper', 'quantity': 12.0, 'unit': 'servings', 'raw': 'fresh ground black pepper to taste'}, {'id': 's_9152', 'name': 'juice of lemon', 'quantity': 1.0, 'unit': '', 'raw': 'juice from 1 lemon'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 - 3 tablespoons olive oil (or more to achieve your desired consistency'}, {'id': 's_11819', 'name': 'chilies', 'quantity': 2.0, 'unit': '', 'raw': '2 fresh green or red chilies, seeded and chopped'}, {'id': 's_1012047', 'name': 'sea salt', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon sea salt, or to taste'}, {'id': 's_12698', 'name': 'tahini', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup tahini'}, {'id': 's_2043', 'name': 'turmeric', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon turmeric'}]}, {'id': 's_716361', 'title': 'Stir Fried Quinoa, Brown Rice and Chicken Breast', 'instructions': 'In a bowl, season the chicken breast with the seasoning cubes and suya spice and allow to marinate for 2 hours or if you are really hungry, you can use immediately.In a pot of boiling water (1 cup), pour in your quinoa mix and the teaspoon of oil and allow to boil till soft which should take about 5-7 minutes. Pour into a bowl and set aside.In a pan, heat up the melted butter and pan fry on medium heat the chicken breast, constantly flipping it over so it browns\xa0on both sides, reduce the heat, cover the pan and allow the chicken cook properly. If the pan becomes to dry, add 2 tablespoons of water.Stir in the chopped vegetables into the pan of frying chicken and finally add the quinoa/brown rice mix. Serve hot!', 'servings': 1, 'url': 'https://www.afrolems.com/2014/06/26/stir-fried-quinoa-brown-rice-and-chicken-breast/', 'cuisine': '', 'diets': ['gluten free'], 'ingredients': [{'id': 's_1032027', 'name': 'suya spice', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of suya spice or Yaji (optional)'}, {'id': 's_20040', 'name': 'quinoa and brown rice mix', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup of quinoa and brown rice mix'}, {'id': 's_1001', 'name': 'butter', 'quantity': 1.5, 'unit': 'teaspoon', 'raw': '1.5 teaspoon of melted butter'}, {'id': 's_11124', 'name': 'carrots', 'quantity': 1.0, 'unit': 'handful', 'raw': 'A handful of chopped carrots'}, {'id': 's_10311529', 'name': 'cherry tomatoes', 'quantity': 4.0, 'unit': '', 'raw': '4 whole cherry tomatoes (optional)'}, {'id': 's_5062', 'name': 'chicken breast', 'quantity': 1.0, 'unit': '', 'raw': '1 chicken breast (Thinly sliced)'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 2.0, 'unit': 'cloves', 'raw': '2 cloves of garlic'}, {'id': 's_99186', 'name': 'seasoning cubes', 'quantity': 1.0, 'unit': 'serving', 'raw': 'Seasoning cubes'}, {'id': 's_11333', 'name': 'bell pepper', 'quantity': 1.0, 'unit': 'handful', 'raw': 'A handful of chopped green pepper'}, {'id': 's_10211529', 'name': 'roma tomato', 'quantity': 1.0, 'unit': 'medium', 'raw': '1 medium roma tomato'}, {'id': 's_10011819', 'name': 'scotch bonnet pepper', 'quantity': 1.0, 'unit': '', 'raw': '1 scotch bonnet pepper (ata rodo)'}, {'id': 's_11291', 'name': 'spring onion', 'quantity': 1.0, 'unit': '', 'raw': '1 chopped spring onion'}, {'id': 's_4669', 'name': 'vegetable oil', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of vegetable oil'}, {'id': 's_14412', 'name': 'water', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup water'}]}, {'id': 's_765011', 'title': 'Snap Pea and Green Bean Salad with Arugula Pesto', 'instructions': 'Bring a large pot of salted water to a boil.While your water is coming to a boil, prepare your arugula pesto and cilantro cream drizzle.In the bowl of your food processor, add the almonds, pistachios, garlic, lemon zest, baby arugula and basil leaves. Pulse 8-9 times until completely broken up. With the food processor running, slowly pour in the olive oil until the pesto just comes together. Season to taste with salt and black pepper and transfer to a large bowl.In the same food processor bowl (wipe clean if you wish), combine the yogurt and cilantro. Pulse until the two ingredients come together. Season to taste with salt and black pepper and set aside.Have an ice bath ready. Add the snap peas and beans to the boiling water and blanch for about 1 minute and 30 seconds. Drain and transfer immediately to the ice bath to cool down. Drain again once the veggies are cool, and pat them dry. Add the veggies to the bowl with the pesto and toss to coat. Pour the veggies onto a large platter and drizzle with the cilantro cream. Top with micro greens and sliced almonds. Enjoy immediately or place in the refrigerator to chill.', 'servings': 6, 'url': 'https://www.pinkwhen.com/snap-pea-green-bean-salad-arugula-pesto/', 'cuisine': '', 'diets': ['gluten free', 'lacto ovo vegetarian', 'primal'], 'ingredients': [{'id': 's_12061', 'name': 'roasted almonds', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup roasted almonds'}, {'id': 's_12061', 'name': 'almonds', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon slice almonds'}, {'id': 's_10011959', 'name': 'baby arugula', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups baby arugula'}, {'id': 's_2044', 'name': 'basil leaves', 'quantity': 4.0, 'unit': '', 'raw': '4 basil leaves'}, {'id': 's_11165', 'name': 'cilantro', 'quantity': 0.5, 'unit': 'cup', 'raw': '½ cup cilantro'}, {'id': 's_1034053', 'name': 'extra virgin olive oil', 'quantity': 0.5, 'unit': 'cup', 'raw': '½ cup extra virgin olive oil (more as needed)'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 3.0, 'unit': 'cloves', 'raw': '3 cloves of garlic'}, {'id': 's_21052', 'name': 'micro greens', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup micro greens or sprouts'}, {'id': 's_9156', 'name': 'lemon zest', 'quantity': 1.0, 'unit': '', 'raw': 'zest from 1 lemon'}, {'id': 's_12151', 'name': 'pistachios', 'quantity': 0.5, 'unit': 'cup', 'raw': '½ cup shelled pistachios'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 6.0, 'unit': 'servings', 'raw': 'salt and black pepper'}, {'id': 's_10011300', 'name': 'snap peas', 'quantity': 1.0, 'unit': 'pound', 'raw': '1 pound snap peas'}, {'id': 's_93711', 'name': 'wax beans', 'quantity': 1.0, 'unit': 'pound', 'raw': '1 pound green or wax beans'}, {'id': 's_1001116', 'name': 'yogurt', 'quantity': 0.5, 'unit': 'cup', 'raw': '½ cup plain yogurt or sour cream'}]}, {'id': 's_660228', 'title': 'Skinny Kale Basil Pesto', 'instructions': 'Remove the kale and basil leaves from the stem and rinse. Roughly chop the kale leaves so that they fit inside a food processor. Place the kale and basil leaves into a food processor and chop until the leaves turn into small pieces. Add the rest of the ingredients into the food processor and mix until everything is well blended. Pour out all the ingredients into a dish and enjoy with your favorite dishes!', 'servings': 3, 'url': 'https://www.foodista.com/recipe/6K5LNQ7F/skinny-kale-basil-pesto', 'cuisine': '', 'diets': ['gluten free'], 'ingredients': [{'id': 's_11233', 'name': 'kale leaves', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups packed kale leaves'}, {'id': 's_2044', 'name': 'basil leaves', 'quantity': 1.5, 'unit': 'cups', 'raw': '1.5 cups packed basil leaves'}, {'id': 's_9152', 'name': 'juice of lemon', 'quantity': 0.5, 'unit': '', 'raw': '1/2 small lemon, juiced'}, {'id': 's_10211215', 'name': 'garlic cloves', 'quantity': 3.0, 'unit': '', 'raw': '3 garlic cloves'}, {'id': 's_16112', 'name': 'miso paste', 'quantity': 1.0, 'unit': 'tbs', 'raw': '1 Tbs miso paste'}, {'id': 's_1032', 'name': 'parmesan cheese', 'quantity': 2.0, 'unit': 'tbs', 'raw': '2 Tbs freshly grated parmesan cheese'}, {'id': 's_10112155', 'name': 'walnuts', 'quantity': 0.5, 'unit': 'tbs', 'raw': '1/2 Tbs chopped walnuts'}, {'id': 's_14412', 'name': 'water', 'quantity': 1.0, 'unit': 'tbs', 'raw': '1 Tbs water'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 0.5, 'unit': 'tbs', 'raw': '1/2 Tbs olive oil'}]}, {'id': 's_716408', 'title': 'Greek-Style Baked Fish: Fresh, Simple, and Delicious', 'instructions': 'Preheat the oven to 450 degrees F. Choose an oven-proof baking dish that your fish will fit in without overlapping and spray it with cooking spray. Lay the fish fillets in the baking pan in a single layer, season with salt and pepper, then top the fish with red onion and bell pepper. Sprinkle with dried basil and oregano, the tomato, and the feta cheese, then drizzle the white wine and olive oil over top. Grind some fresh pepper over the top. Bake uncovered for about 12 – 15 minutes or until the fish flakes easily with a fork. Squeeze the lemon wedges over the cooked fish, garnish with the fresh basil and/or oregano and serve with hot cooked rice.', 'servings': 4, 'url': 'https://fullbellysisters.blogspot.com/2012/04/greek-style-baked-fish-fresh-simple-and.html', 'cuisine': 'mediterranean', 'diets': ['gluten free', 'pescatarian'], 'ingredients': [{'id': 's_10211821', 'name': 'bell pepper', 'quantity': 1.0, 'unit': '', 'raw': '1 bell pepper'}, {'id': 's_10220445', 'name': 'rice', 'quantity': 4.0, 'unit': 'servings', 'raw': 'Cooked rice, for serving'}, {'id': 's_2003', 'name': 'basil', 'quantity': 1.0, 'unit': 'tsp', 'raw': '1 tsp Dried basil'}, {'id': 's_1019', 'name': 'feta cheese', 'quantity': 2.0, 'unit': 'oz', 'raw': '2 – 3 oz. of crumbled feta cheese per pound of fish'}, {'id': 's_10115261', 'name': 'fish fillets', 'quantity': 1.0, 'unit': 'lb', 'raw': '1 lb fish fillets'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 Tablespoons olive oil per pound of fish'}, {'id': 's_2027', 'name': 'oregano', 'quantity': 1.0, 'unit': 'tsp', 'raw': '1 tsp dried oregano'}, {'id': 's_1002030', 'name': 'pepper', 'quantity': 4.0, 'unit': 'servings', 'raw': 'Freshly ground pepper'}, {'id': 's_10011282', 'name': 'onion', 'quantity': 0.5, 'unit': '', 'raw': '1/2 Red onion'}, {'id': 's_1102047', 'name': 'salt & pepper', 'quantity': 4.0, 'unit': 'servings', 'raw': 'Salt & pepper'}, {'id': 's_11529', 'name': 'tomato', 'quantity': 1.0, 'unit': '', 'raw': '1 tomato'}, {'id': 's_14106', 'name': 'white wine', 'quantity': 0.25, 'unit': 'cup', 'raw': '¼ cup white wine'}]}, {'id': 's_661340', 'title': 'Spinach Salad with Strawberry Vinaigrette', 'instructions': 'Place everything on a plate!  :) Place all ingredient in a blender and process until smooth, about 30 seconds Makes 1 cup Calories per Tbsp.  3,  Fat:  .01,  Sodium:  10,  Potassium:  13,  Carbs:  1,  Fiber:  .01,  Sugar:  .03,  Protein:  .01', 'servings': 1, 'url': 'https://www.foodista.com/recipe/5HT32BN5/spinach-salad-with-strawberry-vinaigrette', 'cuisine': '', 'diets': ['gluten free', 'primal'], 'ingredients': [{'id': 's_10112061', 'name': 'almonds', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 tbsp. sliced almonds'}, {'id': 's_2069', 'name': 'balsamic vinegar', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup – balsamic vinegar'}, {'id': 's_5114', 'name': 'chicken', 'quantity': 2.0, 'unit': 'oz', 'raw': '2 oz of chicken – cooked'}, {'id': 's_1032046', 'name': 'dijon mustard', 'quantity': 1.25, 'unit': 'tsp', 'raw': '1 1/4 tsp. dijon mustard'}, {'id': 's_1019', 'name': 'feta cheese', 'quantity': 0.5, 'unit': 'oz', 'raw': '1/2 oz. feta cheese'}, {'id': 's_1012049', 'name': 'thyme', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp. fresh thyme'}, {'id': 's_1002030', 'name': 'ground pepper', 'quantity': 0.25, 'unit': 'tsp', 'raw': '1/4 tsp. ground pepper'}, {'id': 's_11677', 'name': 'shallot', 'quantity': 0.5, 'unit': '', 'raw': '1/2 shallot – chopped'}, {'id': 's_10011457', 'name': 'spinach leaves', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups fresh spinach leaves'}, {'id': 's_9316', 'name': 'strawberries', 'quantity': 0.6666667, 'unit': 'cup', 'raw': '2/3 cup strawberries - chopped'}, {'id': 's_9316', 'name': 'strawberries', 'quantity': 4.0, 'unit': '', 'raw': '4 strawberries - sliced'}, {'id': 's_14412', 'name': 'water', 'quantity': 0.25, 'unit': 'cup', 'raw': '1/4 cup water'}]}, {'id': 's_659135', 'title': 'Salmon with roasted vegetables', 'instructions': 'Season the salmon fillets with some salt, pepper and a pinch of paprika and keep aside. Preheat the oven to 200 C.  Roughly dice the potatoes, parsnips and carrots and add to a roasting tray. Drizzle over the olive oil and season with salt and pepper. Mix well and roast for 15 minutes. Add in the onion and roast for a further 10-15 minutes Place the salmon fillets and tomatoes between the veg. Drizzle the lemon juice and sprinkle over the rosemary and thyme. Season lightly with salt and pepper and roast for 10-15 minutes or until the salmon and veg is cooked through. Serve with some green salad.', 'servings': 2, 'url': 'https://www.foodista.com/recipe/7TTSVX56/salmon-with-roasted-vegetables', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'whole 30', 'pescatarian'], 'ingredients': [{'id': 's_11352', 'name': 'potato', 'quantity': 1.0, 'unit': '', 'raw': '1 potato'}, {'id': 's_11298', 'name': 'parsnip', 'quantity': 1.0, 'unit': '', 'raw': '1 parsnip'}, {'id': 's_11124', 'name': 'carrot', 'quantity': 1.0, 'unit': '', 'raw': '1 carrot'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': '', 'raw': '1 onion, sliced'}, {'id': 's_10311529', 'name': 'cherry tomatoes', 'quantity': 150.0, 'unit': 'g', 'raw': '150 g cherry tomatoes'}, {'id': 's_10115076', 'name': 'salmon', 'quantity': 2.0, 'unit': 'fillet', 'raw': '2 salmon fillets'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.0, 'unit': 'tbsp', 'raw': '1 tbsp olive oil'}, {'id': 's_9152', 'name': 'lemon juice', 'quantity': 1.0, 'unit': 'tsp', 'raw': '1 tsp lemon juice'}, {'id': 's_1042027', 'name': 'salt', 'quantity': 2.0, 'unit': 'servings', 'raw': 'Salt, pepper and paprika for seasoning'}, {'id': 's_2063', 'name': 'rosemary and thyme', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2 tsp of fresh rosemary and thyme, chopped'}]}, {'id': 's_639851', 'title': 'Cod with Tomato-Olive-Chorizo Sauce and Mashed Potatoes', 'instructions': 'If frozen, thaw completely the cod fillets, and dry them with paper towels. season with salt and set aside.Peel and quarter the potatoes, and cook in lightly salted water until tender.Meanwhile, fry the pepper in olive oil for 3-4 minutes. Add cubed sausage, saut for another 2-3 minutes. Add the whole plum tomatoes,  halve them with a flat end of a wooden spoon.Stir in olives and parsley, cook the sauce gently for 2 minutes. Set aside. Drain the potatoes and season with parsley, olive oil and lemon juice. Use a hand masher to mix and mash. Leave in a warm place. Place the cod fillets into a hot oiled non-stick pan and cook over a high heat for 5 minutes on each side or until golden brown. Serve with mashed potatoes and sauce.', 'servings': 2, 'url': 'https://www.foodista.com/recipe/GNSQNH5W/cod-with-tomatoes-olives-and-chorizo', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'whole 30'], 'ingredients': [{'id': 's_1059195', 'name': 'olives', 'quantity': 50.0, 'unit': 'g', 'raw': '50g pitted black olives, halved'}, {'id': 's_15015', 'name': 'cod fillets', 'quantity': 500.0, 'unit': 'g', 'raw': '500 g cod fillets, fresh or frozen'}, {'id': 's_10511297', 'name': 'parsley', 'quantity': 4.0, 'unit': 'tbs', 'raw': '4 Tbs fresh parsley, chopped'}, {'id': 's_10511297', 'name': 'parsley leaves', 'quantity': 2.0, 'unit': 'servings', 'raw': 'Fresh parsley leaves, chopped'}, {'id': 's_9152', 'name': 'lemon juice', 'quantity': 1.0, 'unit': 'tbs', 'raw': '1 Tbs lemon juice'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.0, 'unit': 'tbs', 'raw': '1 Tbs olive oil'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tbs', 'raw': '2 Tbs olive oil'}, {'id': 's_10411529', 'name': 'plum tomatoes', 'quantity': 240.0, 'unit': 'g', 'raw': '240g whole plum tomatoes, canned'}, {'id': 's_11352', 'name': 'potatoes', 'quantity': 300.0, 'unit': 'g', 'raw': '300 g potatoes'}, {'id': 's_10211821', 'name': 'bell pepper', 'quantity': 100.0, 'unit': 'g', 'raw': '100g fresh red pepper, trimmed, cut into small strips'}, {'id': 's_2047', 'name': 'salt', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp salt'}, {'id': 's_7916', 'name': 'a semi-smoked sausage', 'quantity': 100.0, 'unit': 'g', 'raw': '100g chorizo or a semi-smoked sausage, cubed'}]}, {'id': 's_664547', 'title': 'Vegetable Dip', 'instructions': 'In a medium bowl combine all ingredients (except raw vegetables for dipping). Cover and refrigerate until ready to serve. Serve as a dip for raw vegetables. Makes approximately 3 cups.', 'servings': 3, 'url': 'https://www.foodista.com/recipe/WMHFXKKF/vegetable-dip', 'cuisine': '', 'diets': ['gluten free', 'lacto ovo vegetarian', 'primal'], 'ingredients': [{'id': 's_11463', 'name': 'spinach', 'quantity': 10.0, 'unit': 'oz', 'raw': '1 package frozen chopped spinach, thawed & drained (10 oz)'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': 'cup', 'raw': 'cup fresh onion, minced'}, {'id': 's_1117', 'name': 'lowfat yogurt', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups plain lowfat yogurt'}, {'id': 's_11583', 'name': 'vegetables', 'quantity': 3.0, 'unit': 'servings', 'raw': 'Assorted raw vegetables for dipping'}]}, {'id': 's_633921', 'title': 'Balsamic & Honey Glazed Salmon with Lemony Asparagus', 'instructions': 'In a small mixing bowl or blender, combine all of the ingredients for the balsamic marinade except for the lemon juice (balsamic vinegar, apple cider vinegar, 1 tbsp grapeseed oil, honey, dried dill, herbs de provence, salt and pepper). Whisk or blend until oil and vinegar are well incorporated and no longer separate. Place salmon fillet in a baking dish (I use a small casserole dish). Pour the marinade over the salmon and allow it to marinate for at least 15 minutes (or up to 24 hours covered in the refrigerator).  Turn your oven on high broil. Just before putting the salmon in the oven, drizzle the lemon juice over the fish. Bake for 10 to 12 minutes on the top rack or until salmon is glazed, browned and sizzling.While the salmon is baking, prepare the asparagus.  Wash the asparagus and cut off the bottom inch and a half of each stalk and discard. Spread the asparagus on in a large skillet. Drizzle the grapeseed oil over the asparagus and spread the oil on the asparagus with your hands so that all stalks are completely coated. Sprinkle asparagus with desired amount of salt and pepper. Saute over medium heat for 5 minutes. Add the two tablespoons of vegetable stock and cover the skillet. Saute 4 minutes. Remove lid and add the minced garlic. Place cover back over the asparagus. Continue cooking an additional 3 to 5 minutes until asparagus is cooked but not too soft.  Grate lemon zest over the top of the asparagus.', 'servings': 2, 'url': 'https://www.foodista.com/recipe/CK5NCLGT/balsamic-honey-glazed-salmon-with-lemony-asparagus', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'pescatarian'], 'ingredients': [{'id': 's_2048', 'name': 'apple cider vinegar', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons apple cider vinegar'}, {'id': 's_11011', 'name': 'asparagus', 'quantity': 12.0, 'unit': 'stalks', 'raw': '12 stalks asparagus'}, {'id': 's_2069', 'name': 'balsamic vinegar', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon balsamic vinegar'}, {'id': 's_2017', 'name': 'dill', 'quantity': 0.125, 'unit': 'teaspoon', 'raw': '2 pinches (1/8 teaspoon) dried dill'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 3.0, 'unit': 'cloves', 'raw': '3 cloves garlic, minced'}, {'id': 's_4517', 'name': 'grapeseed oil', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon grapeseed oil'}, {'id': 's_1012042', 'name': 'herbs de provence', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon herbs de Provence'}, {'id': 's_19296', 'name': 'honey', 'quantity': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon honey'}, {'id': 's_9152', 'name': 'juice of lemon', 'quantity': 2.0, 'unit': '', 'raw': 'Juice of half a lemon'}, {'id': 's_9156', 'name': 'lemon zest', 'quantity': 1.0, 'unit': '', 'raw': 'Zest of 1 lemon'}, {'id': 's_10115076', 'name': 'salmon fillet', 'quantity': 0.5, 'unit': 'pound', 'raw': '0.5 pound salmon fillet'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 2.0, 'unit': 'servings', 'raw': 'Salt and pepper'}, {'id': 's_6615', 'name': 'vegetable stock', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons vegetable stock'}]}, {'id': 's_641057', 'title': 'Curried Butternut Squash and Apple Soup', 'instructions': 'Get ready two small saucepans. In one have together 1/2 of the squash and 1/2 of the apple  bring to a simmer, and simmer until just tender when pierced with a fork. In the other, add in the rest of the vegetables along with 1 cup of water  bring this to a rolling boil, reduce to a simmer, and simmer until very very tender. When very tender, remove the vegetables from the heat, and blend these vegetables together (without draining) with the Braggs, spices, sriracha and the additional 1/2 cup water. Mix the blended part of the soup with the simmered squash and apples. Mix in the cubed tofu, gently re-heat and serve.', 'servings': 1, 'url': 'https://www.foodista.com/recipe/FKQCYKYR/curried-butternut-squash-and-apple-soup', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_11135', 'name': 'cauliflower', 'quantity': 3.5, 'unit': 'oz', 'raw': '1 cup chopped cauliflower (3.5 oz)'}, {'id': 's_11485', 'name': 'butternut squash', 'quantity': 2.5, 'unit': 'oz', 'raw': '1/2 cup chopped butternut squash (2.5 oz)'}, {'id': 's_9003', 'name': 'apple', 'quantity': 2.0, 'unit': 'oz', 'raw': '1/2 cup peeled and chopped apple (2 oz)'}, {'id': 's_14412', 'name': 'water', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup water, plus about 1/2 cup extra'}, {'id': 's_93767', 'name': 'braggs liquid aminos', 'quantity': 2.0, 'unit': 'tsp', 'raw': '2-3 tsp Braggs liquid aminos'}, {'id': 's_1022020', 'name': 'curry powder', 'quantity': 0.5, 'unit': 'tsp', 'raw': '1/2 heaping tsp: curry powder (or even 1 tsp, if you like the heat), garlic powder, onion powder'}, {'id': 's_2021', 'name': 'ginger powder', 'quantity': 0.25, 'unit': 'tsp', 'raw': '1/4 tsp ginger powder'}, {'id': 's_1016168', 'name': 'a squirt sriracha', 'quantity': 0.125, 'unit': 'tsp', 'raw': 'a small squirt (1/8 tsp) sriracha'}, {'id': 's_10016213', 'name': 'block lite tofu', 'quantity': 0.125, 'unit': '', 'raw': '1/8 block pressed lite firm tofu, cubed'}]}, {'id': 's_632269', 'title': 'Amaranth and Roast Veggie Salad', 'instructions': 'Cook the amaranth with about a cup of water until it reaches a sticky consistency Cut the onion roughly into chunks Add the onion and diced pumpkin to a tinfoil lined baking tray Drizzled over the olive oil and sprinkle with the herbal salt and pepper Put into a hot oven and roast until the edges of the pumpkin go crispy Just before the veggies are done, throw in the baby tomatoes Coat the veggies in the cooked amaranth Tear a few rocket leaves Toss together and there you have it, an unusual roast veggie salad! Serve warm', 'servings': 2, 'url': 'https://www.foodista.com/recipe/BPXZ2RCY/amaranth-and-roast-veggie-salad', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_20001', 'name': 'amaranth', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup amaranth'}, {'id': 's_1044053', 'name': 'basil-infused olive oil', 'quantity': 2.0, 'unit': 'servings', 'raw': 'basil-infused olive oil'}, {'id': 's_10211821', 'name': 'bell pepper', 'quantity': 2.0, 'unit': 'servings', 'raw': 'pepper'}, {'id': 's_11422', 'name': 'pumpkin', 'quantity': 0.5, 'unit': 'packet', 'raw': '1/2 packet diced pumpkin'}, {'id': 's_10011282', 'name': 'onion', 'quantity': 1.0, 'unit': '', 'raw': '1 red onion'}, {'id': 's_11959', 'name': 'rocket leaves', 'quantity': 9.0, 'unit': 'servings', 'raw': 'few rocket leaves'}, {'id': 's_2047', 'name': 'herbal salt', 'quantity': 2.0, 'unit': 'servings', 'raw': 'herbal salt'}, {'id': 's_11529', 'name': 'punnet baby tomatoes', 'quantity': 0.5, 'unit': '', 'raw': '1/2 punnet (basket) baby tomatoes'}]}, {'id': 's_637162', 'title': 'Carrot and Cabbage Salad With Coriander+cumin Dry Rub', 'instructions': 'Chop up the carrots and the cabbage into slivers of roughly the same size. Add the ground coriander, cumin seed, lime juice, and olive oil and massage it into the veggies. Add the fresh coriander and sunflower seeds on top.Leave aside for a couple of hours for the spices to seep into the veggies for added flavor.', 'servings': 1, 'url': 'https://www.foodista.com/recipe/MB7NYM87/carrot-and-cabbage-salad-with-coriandercumin-dry-rub', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'fodmap friendly', 'whole 30', 'vegan'], 'ingredients': [{'id': 's_11124', 'name': 'carrots', 'quantity': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups of carrots'}, {'id': 's_2014', 'name': 'cumin seed powder', 'quantity': 0.5, 'unit': 'tsp', 'raw': '1/2 tsp cumin seed powder'}, {'id': 's_11165', 'name': 'coriander', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch of fresh coriander'}, {'id': 's_11109', 'name': 'cabbage', 'quantity': 0.75, 'unit': 'cup', 'raw': '3/4 cup green cabbage'}, {'id': 's_1002013', 'name': 'ground coriander', 'quantity': 0.5, 'unit': 'tsp', 'raw': '1/2 tsp ground coriander'}, {'id': 's_9160', 'name': 'juice of lime', 'quantity': 1.0, 'unit': '', 'raw': '1 Juice of lime'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of olive oil'}, {'id': 's_11112', 'name': 'cabbage', 'quantity': 0.75, 'unit': 'cup', 'raw': '3/4 cup red cabbage'}, {'id': 's_12036', 'name': 'sunflower seeds', 'quantity': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons of sunflower seeds'}]}, {'id': 's_982371', 'title': 'Instant Pot Quinoa Grain Bowl', 'instructions': 'Rinse and drain the quinoa to remove the bitter and sometimes mildly soapy taste that can linger if not rinsed. Combine the quinoa, stock and seasonings in the Instant Pot together and then twist to lock the lid shut. Set the pot to Manual for 1 minute. At the end of the cook time, let the pot to natural pressure release for 10 minutes before carefully releasing the remaining pressure. Fluff the cooked quinoa with a fork. Now you have Instant Pot Quinoa! Add fruits and vegetables over a scoop of cooked quinoa and make an amazing quinoa grain bowl.', 'servings': 4, 'url': 'https://www.pinkwhen.com/instant-pot-quinoa-grain-bowl/', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_9037', 'name': 'avocado', 'quantity': 0.5, 'unit': '', 'raw': '½ ripe avocado sliced'}, {'id': 's_11090', 'name': 'broccoli', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup chopped broccoli'}, {'id': 's_10311529', 'name': 'rainbow cherry tomatoes', 'quantity': 4.0, 'unit': 'servings', 'raw': 'fresh rainbow cherry tomatoes sliced'}, {'id': 's_9433', 'name': 'clementine', 'quantity': 1.0, 'unit': '', 'raw': '1 clementine peeled'}, {'id': 's_11233', 'name': 'kale', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups of chopped kale'}, {'id': 's_20035', 'name': 'quinoa', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups quinoa'}, {'id': 's_1102047', 'name': 'salt and pepper', 'quantity': 4.0, 'unit': 'servings', 'raw': 'salt and pepper to taste'}, {'id': 's_11001', 'name': 'baby brussell sprouts', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup baby brussell sprouts'}, {'id': 's_1006615', 'name': 'stock', 'quantity': 2.0, 'unit': 'cups', 'raw': '2 cups stock or broth'}]}, {'id': 's_1095753', 'title': 'Roasted Cauliflower Detox Bowl with Tahini Sauce', 'instructions': 'Soak the cashews overnight in water.Preheat the oven to 200C/~395 F. Chop the cauliflower into florets and toss with the olive oil and ground cumin. Roast for 20-25 minutes until golden.To make the sauce, add all ingredients except the water and salt to a food processor. While blending, drizzle in the water a little at a time until the sauce starts to become smooth. Continue processing, scraping down the sides or adding additional water as needed, until the sauce is as smooth as your food processor can make it. Add salt to taste.Boil the quinoa in a saucepan for 10 minutes then drain and set aside. Meanwhile, chop the kale and red cabbage into thin strips and saute in a frying pan with the minced garlic clove over a medium heat until wilted. Add in the quinoa and toss so everything is mixed together. Place some of the kale mixture in the bottom of a bowl and top with sliced avocado, some of the roasted cauliflower, a drizzle of the tahini sauce and if desired, sprinkle some cress on the top.', 'servings': 2, 'url': 'https://www.foodista.com/recipe/6J6KLYH6/roasted-cauliflower-detox-bowl-with-tahini-sauce', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ingredients': [{'id': 's_11233', 'name': 'kale leaves', 'quantity': 3.0, 'unit': '', 'raw': '3 Large Kale Leaves'}, {'id': 's_11215', 'name': 'garlic', 'quantity': 1.0, 'unit': 'clove', 'raw': '1 clove garlic'}, {'id': 's_20035', 'name': 'quinoa', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup Quinoa'}, {'id': 's_11112', 'name': 'cabbage', 'quantity': 0.25, 'unit': '', 'raw': '1/4 Red Cabbage'}, {'id': 's_9037', 'name': 'avocado', 'quantity': 1.0, 'unit': '', 'raw': '1 Avocado'}, {'id': 's_11135', 'name': 'a cauliflower', 'quantity': 0.5, 'unit': '', 'raw': '1/2 a Large Cauliflower'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 1.0, 'unit': 'tsp', 'raw': '1 tsp olive oil'}, {'id': 's_1012014', 'name': 'ground cumin', 'quantity': 0.25, 'unit': 'tsp', 'raw': '1/4 tsp Ground Cumin'}, {'id': 's_11203', 'name': 'garden cress', 'quantity': 2.0, 'unit': 'servings', 'raw': 'garden cress'}, {'id': 's_10311215', 'name': 'garlic roasted', 'quantity': 1.0, 'unit': 'head', 'raw': '1 head garlic roasted'}, {'id': 's_14412', 'name': 'cashews soaked overnight in water', 'quantity': 0.5, 'unit': 'cup', 'raw': '1/2 cup Raw Cashews soaked overnight in water'}, {'id': 's_12698', 'name': 'tahini', 'quantity': 2.0, 'unit': 'tbsp', 'raw': '2 tbsp Tahini'}, {'id': 's_14412', 'name': 'water', 'quantity': 4.0, 'unit': 'tbsp', 'raw': '4-6 tbsp Water or more, as needed'}, {'id': 's_1082047', 'name': 'kosher salt', 'quantity': 0.25, 'unit': 'tsp', 'raw': '1/4-1/2 tsp Kosher Salt'}]}, {'id': 's_660405', 'title': 'Smoky Black Bean Soup With Sweet Potato & Kale', 'instructions': 'Spread the dry beans out on a baking sheet and pick out any pebbles. Place the beans in a big soup pot, cover with water by 3 inches and allow them to soak overnight or for 6-8 hours, then discard that water. Return the soaked beans to the pot and cover with 3 inches of water again, bring to a boil. Reduce heat to medium low, put the cover on and allow to cook until the beans start to get tender but still firm, about 1 1/2 hours. Drain the beans. Heat the oil in a soup pot over med-high heat. Add the onion along with a pinch of salt and saute until softened and golden. Stir in 1 tbsp of ground cumin, add the beans along with the broth or water and bring to a boil. Reduce heat to medium-low, cover and cook for 30 min. Meanwhile peel and chop the sweet potatoes. Wash the kale, remove the stems and chop the leaves. Remove half of the beans and liquid and set aside to cool a bit. Add the sweet potatoes and kale to the pot with some salt and pepper. Cover and cook for 10 minutes. Transfer the cooled beans to a blender and puree until smooth, then return them to the pot. Stir in the remaining 1 tbsp of ground cumin. Now add 1 tbsp of the chipotles in adobo. Taste and continue to add more until it has a spice level that you like. Adjust the salt &amp; pepper as needed. Serve with a dollop of sour cream.', 'servings': 6, 'url': 'https://www.foodista.com/recipe/B8SQD87X/smoky-black-bean-soup-with-sweet-potato-kale', 'cuisine': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian'], 'ingredients': [{'id': 's_6194', 'name': 'chicken broth', 'quantity': 6.0, 'unit': 'cups', 'raw': '6 cups Chicken Broth or Water'}, {'id': 's_98839', 'name': 'chipotle chiles', 'quantity': 3.0, 'unit': 'tablespoons', 'raw': '3 tablespoons Chipotle chiles'}, {'id': 's_16014', 'name': 'black beans', 'quantity': 1.0, 'unit': 'pound', 'raw': '1 pound Dried Black Beans'}, {'id': 's_1012014', 'name': 'ground cumin', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons Ground Cumin'}, {'id': 's_11233', 'name': 'kale', 'quantity': 1.0, 'unit': 'bunch', 'raw': '1 bunch kale'}, {'id': 's_4053', 'name': 'olive oil', 'quantity': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons olive oil'}, {'id': 's_11282', 'name': 'onion', 'quantity': 1.0, 'unit': '', 'raw': '1 Onion – Chopped'}, {'id': 's_1102047', 'name': 'salt & pepper', 'quantity': 6.0, 'unit': 'servings', 'raw': 'Salt & Pepper'}, {'id': 's_11507', 'name': 'sweet potatoes', 'quantity': 3.0, 'unit': 'lbs', 'raw': '3 lbs sweet potatoes'}]}, {'id': 's_715523', 'title': 'Chorizo and Beef Quinoa Stuffed Pepper', 'instructions': 'The first thing you will want to do is heat the oven to 350, boil the water for the quinoa, and in a separate skillet brown the beef and chorizo together. Drain the meat mixture well, and then place into a medium mixing bowl.Once your quinoa is fully cooked, add it to the mixing bowl. Add the green onion tops, cumin, cayenne, chili powder, and monterrey jack and cheddar cheese. Mix well. Cut the tops from your bell peppers and scoop out any remaining seeds.Then take your meat mixture and start stuffing the bell peppers until they are full. Sprinkle with a little cheese and then bake in the oven for about 10 minutes until the bell pepper has softened. Serve immediately.', 'servings': 4, 'url': 'https://www.pinkwhen.com/chorizo-and-beef-quinoa-stuffed-pepper-recipe/', 'cuisine': '', 'diets': ['gluten free'], 'ingredients': [{'id': 's_10211821', 'name': 'bell peppers', 'quantity': 4.0, 'unit': 'servings', 'raw': 'bell peppers'}, {'id': 's_2031', 'name': 'cayenne', 'quantity': 0.5, 'unit': 'tsp', 'raw': '½ tsp cayenne'}, {'id': 's_2009', 'name': 'chili powder', 'quantity': 0.25, 'unit': 'tsp', 'raw': '¼ tsp chili powder'}, {'id': 's_99233', 'name': 'chorizo', 'quantity': 1.0, 'unit': 'pound', 'raw': '1 pound chorizo'}, {'id': 's_1002014', 'name': 'cumin', 'quantity': 0.25, 'unit': 'tsp', 'raw': '¼ tsp cumin'}, {'id': 's_11291', 'name': 'green onion tops', 'quantity': 4.0, 'unit': 'servings', 'raw': 'green onion tops'}, {'id': 's_1001025', 'name': 'monterrey jack and cheddar cheese', 'quantity': 0.25, 'unit': 'cup', 'raw': '¼ cup mixed monterrey jack and cheddar cheese'}, {'id': 's_23557', 'name': 'ground beef', 'quantity': 1.0, 'unit': 'pound', 'raw': '1 pound lean ground beef'}, {'id': 's_20035', 'name': 'quinoa', 'quantity': 1.0, 'unit': 'cup', 'raw': '1 cup quinoa'}]}]
