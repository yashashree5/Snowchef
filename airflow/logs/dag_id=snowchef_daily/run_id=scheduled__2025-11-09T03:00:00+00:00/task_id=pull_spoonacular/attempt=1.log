[2025-11-10T03:08:55.960+0000] {python.py:240} INFO - Done. Returned value was: {'recipes': [{'rid': 's_637297', 'title': 'Cauliflower Chickpea Stew', 'inst': 'Heat olive oil in large sauce pan on high heat. Crush the garlic and fry it with tumeric, salt and pepper for a minute before adding the brown rice. Fry the rice for another 4-5 minutes before adding the water. Bring the water to a boil and turn down the heat to low-medium, allow to simmer for 30 minutes. Heat olive oil in large saucepan on high heat. Add the onion and fry for 4-5 minutes or until golden brown. Turn down the heat to medium and add the chopped tomatoes, tomato puree, chili, ginger, garlic and the rest of the spices. Add sweet potato, lemon juice and water and bring it to a boil before turning down the heat to medium and allow the stew to simmer for 30-35 minutes. Ten minutes before done, add the cauliflower. Five minutes before done, drain the chickpeas and add them to the stew. The vegetables should be cooked all the way through but it still have a slight snap to them. Season with salt and pepper before serving. Serve with fresh herbs, such as basil or cilantro.', 'serv': 4, 'url': 'https://www.foodista.com/recipe/BQBJ3XVS/cauliflower-chickpea-stew', 'cui': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ings': [{'iid': 's_4053', 'name': 'olive oil', 'qty': 1.0, 'unit': 'tbsp', 'raw': '1 tbsp olive oil'}, {'iid': 's_20040', 'name': 'brown rice', 'qty': 240.0, 'unit': 'g', 'raw': '5/4 cup brown rice (240 g)'}, {'iid': 's_14412', 'name': 'twice amount of water', 'qty': 4.0, 'unit': 'servings', 'raw': 'Twice amount of water'}, {'iid': 's_11215', 'name': 'garlic gloves', 'qty': 2.0, 'unit': '', 'raw': '2 garlic gloves, crushed'}, {'iid': 's_2043', 'name': 'tumeric', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp tumeric'}, {'iid': 's_1102047', 'name': 'salt & pepper', 'qty': 4.0, 'unit': 'servings', 'raw': 'salt & pepper'}, {'iid': 's_11282', 'name': 'onion', 'qty': 1.0, 'unit': '', 'raw': '1 onion, chopped finely'}, {'iid': 's_10011693', 'name': 'canned tomatoes', 'qty': 400.0, 'unit': 'g', 'raw': '1 can chopped tomatoes (400 g)'}, {'iid': 's_11547', 'name': 'tomato puree', 'qty': 2.0, 'unit': 'tbsp', 'raw': '2 tbsp tomato puree'}, {'iid': 's_11215', 'name': 'garlic gloves', 'qty': 3.0, 'unit': '', 'raw': '3 garlic gloves, crushed'}, {'iid': 's_10211216', 'name': 'cm ginger', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 cm fresh ginger, grated (about 1 tsp)'}, {'iid': 's_11819', 'name': 'chili', 'qty': 0.5, 'unit': '', 'raw': '1/2-1 fresh chili, chopped finely'}, {'iid': 's_2010', 'name': 'cinnamon', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp cinnamon'}, {'iid': 's_93663', 'name': 'garam masala', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp garam masala'}, {'iid': 's_2028', 'name': 'paprika', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp paprika'}, {'iid': 's_11507', 'name': 'sweet potatoes', 'qty': 1.0, 'unit': '', 'raw': '1-2 sweet potatoes, cubes'}, {'iid': 's_9152', 'name': 'juice of lemon', 'qty': 0.5, 'unit': '', 'raw': '1/2 lemon, juice'}, {'iid': 's_14412', 'name': 'water', 'qty': 240.0, 'unit': 'ml', 'raw': '1 cup water (240 ml)'}, {'iid': 's_11135', 'name': 'cauliflower', 'qty': 0.5, 'unit': 'small', 'raw': '1/2 small cauliflower, bite size pieces'}, {'iid': 's_16058', 'name': 'chickpeas', 'qty': 400.0, 'unit': 'g', 'raw': '1 tin chickpeas (400 g)'}]}, {'rid': 's_1046982', 'title': 'How to Make the Perfect Sweet Potato Sloppy Joes', 'inst': "Preheat the oven to 425 degrees. Pierce the sweet potatoes all over the skin with a fork. Rub the outside of the potatoes with olive oil and cover with foil. Bake in the oven for 1 hour until fully cooked. Brown the ground turkey in a skillet on medium heat. Once it's finished cooking, add the onion, bell pepper, and garlic. Mix well. Cook until the mixture is fully cooked and starts to crumble. Stir in the garlic, water, tomato paste, and tomato sauce. Stir until mixed well. Turn heat down to low and simmer for 20 minutes, stirring occasionally. Remove the sweet potatoes from the foil and slice down the middle. Mash up the insides with a fork and pour the sloppy joe mix over sweet potatoes. Serve and enjoy!", 'serv': 4, 'url': 'https://www.pinkwhen.com/how-to-make-the-perfect-sweet-potato-sloppy-joes/', 'cui': 'american', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'primal', 'whole 30'], 'ings': [{'iid': 's_10211821', 'name': 'bell pepper', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup diced bell pepper'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 1.0, 'unit': 'clove', 'raw': '1 clove garlic diced'}, {'iid': 's_5662', 'name': 'ground turkey', 'qty': 1.5, 'unit': 'pounds', 'raw': '1 1/2 pounds lean ground turkey'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 4.0, 'unit': 'servings', 'raw': 'olive oil'}, {'iid': 's_11282', 'name': 'onion', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup diced onion'}, {'iid': 's_1102047', 'name': 'salt and pepper', 'qty': 4.0, 'unit': 'servings', 'raw': 'salt and pepper to taste'}, {'iid': 's_11507', 'name': 'sweet potatoes', 'qty': 4.0, 'unit': 'large', 'raw': '4 large sweet potatoes'}, {'iid': 's_11887', 'name': 'tomato paste', 'qty': 6.0, 'unit': 'ounces', 'raw': '6 ounces tomato paste'}, {'iid': 's_11549', 'name': 'tomato sauce', 'qty': 14.0, 'unit': 'ounces', 'raw': '14 ounces tomato sauce'}, {'iid': 's_14412', 'name': 'water', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup water'}]}, {'rid': 's_665379', 'title': 'Winter Kimchi', 'inst': 'Soak the quartered cabbage in the brine solution for 4 hours, weighing the cabbage down with a heavy plate. Remove and drain. Place garlic cloves, rice, fermented shrimp, fish sauce, sugar, chilly paste and chilly flakes in a food processor and zap to a smooth paste. Stir in spring onions. Stuff the cabbage with the paste, making sure to stuff in between the individual leaves and coating every inch of it. Place kimchi into an airtight container and leave at room temperature for a day before leaving it to ferment further in the fridge for at least another week before consuming. I left mine for about 3 weeks.', 'serv': 1, 'url': 'https://www.foodista.com/recipe/DPZ3FLTW/winter-kimchi', 'cui': 'korean', 'diets': ['gluten free', 'dairy free', 'pescatarian'], 'ings': [{'iid': 's_11119', 'name': 'napa cabbage', 'qty': 1.0, 'unit': 'small', 'raw': '1 small napa cabbage, (abt ½ kg) quartered lengthways with stems attached and washed'}, {'iid': 's_1002047', 'name': 'brine solution', 'qty': 3.0, 'unit': 'liters', 'raw': 'Brine solution (3- 4 liters water+ 1 ½ cups coarse salt)'}, {'iid': 's_1016973', 'name': 'chilly paste / korean gochujang paste', 'qty': 3.0, 'unit': 'tablespoons', 'raw': '3 tablespoons chilly paste (reduce for less spicy)/ korean gochujang paste'}, {'iid': 's_10220445', 'name': 'bowl rice', 'qty': 0.25, 'unit': '', 'raw': '1/4 bowl cooked rice'}, {'iid': 's_11429', 'name': 'radish', 'qty': 150.0, 'unit': 'grams', 'raw': '150 grams radish, julienned'}, {'iid': 's_11291', 'name': 'spring onions', 'qty': 40.0, 'unit': 'grams', 'raw': '40 grams spring onions, cut into abt 2" lengths'}, {'iid': 's_98899', 'name': 'chilly flakes', 'qty': 15.0, 'unit': 'grams', 'raw': '15 grams chilly flakes'}, {'iid': 's_19335', 'name': 'sugar', 'qty': 10.0, 'unit': 'grams', 'raw': '10 grams sugar'}, {'iid': 's_10211215', 'name': 'garlic bulb', 'qty': 1.0, 'unit': '', 'raw': '1 whole garlic bulb, skinned'}, {'iid': 's_15270', 'name': 'fermented baby shrimps/ cincalok', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons fermented baby shrimps/ cincalok (you can even use brined fish/anchovies)'}, {'iid': 's_6179', 'name': 'fish sauce', 'qty': 0.125, 'unit': 'cup', 'raw': '1/8 cup fish sauce'}]}, {'rid': 's_716342', 'title': 'Chicken Suya', 'inst': 'Heat the oven to 500 F.Wash and season the chicken with the Suya spice, chilli powder, seasoning cubes, salt and drizzle the oil over it. Place the chicken in the oven and grill for 40 minutes. Check the chicken occasionally and flip on both sides so it can cook properly. Serve hot garnished with the onions and tomato and a bit of suya spice sprinkled over the chicken.', 'serv': 1, 'url': 'https://www.afrolems.com/2014/05/27/chicken-suya/', 'cui': '', 'diets': ['gluten free', 'dairy free', 'whole 30', 'ketogenic'], 'ings': [{'iid': 's_1032027', 'name': 'suya spice', 'qty': 1.5, 'unit': 'tablespoons', 'raw': '1.5 Tablespoons of Suya Spice'}, {'iid': 's_5006', 'name': 'chicken', 'qty': 1.0, 'unit': 'pound', 'raw': '1 pound Chicken'}, {'iid': 's_2009', 'name': 'chilli powder', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of chilli powder'}, {'iid': 's_4582', 'name': 'cooking spoon groundnut oil', 'qty': 1.0, 'unit': '', 'raw': '1 cooking spoon groundnut oil'}, {'iid': 's_99186', 'name': 'seasoning cubes', 'qty': 1.0, 'unit': 'serving', 'raw': 'Seasoning cubes'}, {'iid': 's_11282', 'name': 'onions and tomatoes', 'qty': 1.0, 'unit': 'serving', 'raw': 'Onions and Tomatoes for Garnishing'}, {'iid': 's_2047', 'name': 'salt', 'qty': 1.0, 'unit': 'serving', 'raw': 'Salt to taste'}]}, {'rid': 's_654959', 'title': 'Pasta With Tuna', 'inst': 'Cook pasta in a large pot of boiling water until al dente. Drain and return to warm pot. Put olive oil in saucepan and add onion. Saute until transparent. Stir in flour and cook for a few seconds and then whisk in milk. Stir constantly until this thickens. Add peas, tuna (shredded into chunks,) parsley, green onions, cheese and hot pepper sauce. Pour over pasta and stir gently to mix. Serve at once.', 'serv': 4, 'url': 'https://www.foodista.com/recipe/K6QWSKQM/pasta-with-tuna', 'cui': '', 'diets': ['pescatarian'], 'ings': [{'iid': 's_20081', 'name': 'flour', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons Flour'}, {'iid': 's_11291', 'name': 'green onions', 'qty': 1.0, 'unit': 'cup', 'raw': 'cup Green Onions, chopped'}, {'iid': 's_1085', 'name': 'non-fat milk', 'qty': 1.25, 'unit': 'cups', 'raw': '1 1/4 cups Non-Fat Milk'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons Olive Oil'}, {'iid': 's_11282', 'name': 'onion', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons Onion, minced'}, {'iid': 's_1033', 'name': 'parmesan cheese', 'qty': 0.25, 'unit': 'cup', 'raw': '1/4 cup Parmesan Cheese, grated'}, {'iid': 's_10511297', 'name': 'parsley', 'qty': 1.0, 'unit': 'cup', 'raw': 'cup Fresh Parsley or Basil, chopped'}, {'iid': 's_20420', 'name': 'tubular pasta', 'qty': 8.0, 'unit': 'ounces', 'raw': '8 ounces Tubular Pasta'}, {'iid': 's_11304', 'name': 'peas', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup Frozen Peas, thawed'}, {'iid': 's_6168', 'name': 'dsh pepper sauce', 'qty': 1.0, 'unit': '', 'raw': '1 dsh Hot Pepper Sauce'}, {'iid': 's_15121', 'name': 'water-packed tuna', 'qty': 6.5, 'unit': 'ounces', 'raw': '6 1/2 ounces Can Water-Packed Tuna, drained'}]}, {'rid': 's_660231', 'title': 'Skinny Veggie Fried Rice', 'inst': 'Heat a wok or skillet on med-high and add 1 tsp oil. To it add minced ginger and 1 tsp minced garlic. Saute until fragrant but not burnt. Add mushroom pieces. Cook until tender for 5-6 minutes. Keep mushrooms along with any juices aside in a bowl. Heat wok again add 1 tsp oil. To it add remaining garlic. Saute until fragrant and add all the vegetables. Stir it all together on high flame. Add salt, black pepper and splash of soy sauce. Toss to coat and let them cook for few more minutes until they get tender but not soft. You want veggies to be cooked but with a little crunch. Now add the cold already cooked rice and stir it so it all gets mixed together. Do with a gentle hand. Let the rice get warm at med- high flame. Add the remaining 1 tsp oil along with salt, black pepper and soy sauce. Add the mushrooms and tofu(if using). Mix it all together. Toss and taste. Garnish with chopped green parts of green onions and sesame seeds.', 'serv': 2, 'url': 'https://www.foodista.com/recipe/S53BXV6Z/skinny-veggie-fried-rice', 'cui': 'chinese', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ings': [{'iid': 's_4058', 'name': 'sesame oil', 'qty': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp olive oil or sesame oil'}, {'iid': 's_11216', 'name': 'ginger', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp ginger, minced'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp garlic, minced'}, {'iid': 's_11260', 'name': 'mushrooms', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup mushrooms, chopped'}, {'iid': 's_10011168', 'name': 'baby corns', 'qty': 6.0, 'unit': '', 'raw': '6-7 baby corns, cut in round disks'}, {'iid': 's_11291', 'name': 'green onions white part', 'qty': 0.25, 'unit': 'cup', 'raw': '1/4 cup green onions white part, chopped (Keep the chopped green part of green onions for garnishing)'}, {'iid': 's_11124', 'name': 'size carrot', 'qty': 1.0, 'unit': 'small', 'raw': '1 size carrot, chopped in small pieces'}, {'iid': 's_10211821', 'name': 'bell pepper', 'qty': 1.0, 'unit': 'small size', 'raw': '1 small size bell pepper, chopped in small pieces'}, {'iid': 's_16424', 'name': 'soy sauce', 'qty': 1.0, 'unit': 'tbsp', 'raw': '1 Tbsp low sodium soy sauce'}, {'iid': 's_2047', 'name': 'salt', 'qty': 2.0, 'unit': 'servings', 'raw': 'Salt to taste'}, {'iid': 's_1002030', 'name': 'bell pepper', 'qty': 2.0, 'unit': 'servings', 'raw': 'Black pepper to taste'}, {'iid': 's_12023', 'name': 'sesame seeds', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp sesame seeds'}]}, {'rid': 's_647875', 'title': 'Indian-Style Dill and Turmeric Potato Salad', 'inst': 'Heat the olive oil in a large frying pan. Add the garlic and chilli and heat gently until fragrant. Then add the turmeric powder. Fry together for about 30 seconds. Add the potatoes and mix gently to coat with the turmeric. Add a about 1/4 cup of water and let the potatoes cook through. Then add some salt to taste.Take off the heat and add the dill. Serve immediately.', 'serv': 4, 'url': 'https://www.foodista.com/recipe/2LQW8RTQ/indian-style-dill-and-turmeric-potatoes', 'cui': 'indian', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'whole 30', 'vegan'], 'ings': [{'iid': 's_1032009', 'name': 'of chilli flakes', 'qty': 1.0, 'unit': 'pinch', 'raw': 'Large pinch of dried chilli flakes'}, {'iid': 's_2045', 'name': 'dill', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup fresh dill, chopped finely'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 2.0, 'unit': 'cloves', 'raw': '2 cloves of garlic, chopped finely'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 4.0, 'unit': 'servings', 'raw': 'Olive oil'}, {'iid': 's_11352', 'name': 'potatoes', 'qty': 4.0, 'unit': 'large', 'raw': '4 large potatoes, parboiled and chopped into cubes'}, {'iid': 's_2047', 'name': 'salt', 'qty': 4.0, 'unit': 'servings', 'raw': 'Salt to taste'}, {'iid': 's_2043', 'name': 'turmeric powder', 'qty': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon turmeric powder'}]}, {'rid': 's_664419', 'title': 'Vegan Colcannon Soup', 'inst': 'Heat the oil in a large stockpot set over medium-high heat, until it shimmers. Add the leeks, garlic, and celery, and cook, stirring frequently, for 3 to 4 minutes, until the edges are golden. Add the parsnips, potatoes, cabbage, kale, stock, salt, and pepper and stir well. Reduce the heat to medium and cover. Bring the soup to a boil; then reduce the heat to a low simmer. Cook for 30 to 35 minutes, until the vegetables are tender and soft. Add the lemon juice. Using an immersion blender (or working in batches in a blender), pure until completely smooth. Serve immediately or store in an airtight container for up to 3 days.', 'serv': 8, 'url': 'https://www.foodista.com/recipe/LKGLSJ48/vegan-colcannon-soup', 'cui': 'european', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'whole 30', 'vegan'], 'ings': [{'iid': 's_1034053', 'name': 'extra virgin olive oil', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons extra virgin olive oil'}, {'iid': 's_11246', 'name': 'leeks', 'qty': 2.0, 'unit': 'medium', 'raw': '2 medium leeks, tough green outer leaves removed, washed well (see Kitchen Tip), and thinly sliced'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 2.0, 'unit': 'cloves', 'raw': '2 cloves garlic, chopped'}, {'iid': 's_11143', 'name': 'celery', 'qty': 1.0, 'unit': 'stalk', 'raw': '1 stalk celery (with leaves), roughly chopped'}, {'iid': 's_11353', 'name': 'russet potatoes', 'qty': 3.0, 'unit': 'large', 'raw': '3 large russet potatoes, peeled and cut into cubes (about 2 cups)'}, {'iid': 's_11114', 'name': 'savoy cabbage', 'qty': 3.0, 'unit': 'cups', 'raw': '¼ head savoy cabbage, roughly chopped (3 cups)'}, {'iid': 's_11233', 'name': 'kale', 'qty': 8.0, 'unit': 'cups', 'raw': '1 head kale, stemmed and roughly chopped (about 8 cups)'}, {'iid': 's_99253', 'name': 'vegetable broth', 'qty': 8.0, 'unit': 'cups', 'raw': '8 cups Roasted Vegetable Stock or store-bought low-sodium vegetable broth'}, {'iid': 's_1082047', 'name': 'kosher salt', 'qty': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons kosher salt'}, {'iid': 's_1002030', 'name': 'pepper', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon freshly ground black pepper'}, {'iid': 's_9152', 'name': 'juice of lemon', 'qty': 1.0, 'unit': '', 'raw': 'Juice of 1 lemon'}]}, {'rid': 's_640321', 'title': 'Crab Stacks', 'inst': 'COMBINE THE QUINOA, OJ AND STOCK IN A SAUCEPAN. COOK OVER MEDIUM HIGH HEAT UNTIL ALL LIQUID HAS BEEN ABSORBED. REMOVE FROM HEAT AND SET ASIDE. CUT THE LIME INTO QUARTERS. COMBINE THE MANGO AND FRESNO CHILE. SQUEEZE A 1/4 OF THE LIME OVER THE MIXTURE AND MIX TO COMBINE. COMBINE THE TOMATO, CILANTRO, GREEN ONION AND GARLIC. SQUEEZE 1/4 OF THE LIME OVER THE MIXTURE AND STIR TO COMBINE. USING A ROUND MOLD, SPOON SOME OF THE PREPARED QUINOA INTO THE BOTTOM. IF USING THE SALMON- SPOON IN A LAYER OF THE SALMON.- OTHERWISE USE CRAB. TOP WITH A LAYER OF THE TOMATO MIXTURE, THEN AVOCADO. TOP WITH A THIN LAYER OF THE QUINOA, THEN CRAB, FOLLOWED BY AVOCADO, THE MANGO MIXTURE AND MORE CRAB AND FINALLY TOPPED WITH A BIT MORE MANGO MIXTURE. PRESS DOWN AND THEN REMOVE THE MOLDS. GARNISH WITH PICKLED GINGER AND RADISHES AND USE THE REMAINING 1/2 LIME TO SQUEEZE OVER THE STACKS. SERVE COLD.', 'serv': 3, 'url': 'https://www.foodista.com/recipe/CYLKTQPJ/crab-stacks', 'cui': '', 'diets': ['gluten free', 'dairy free', 'pescatarian'], 'ings': [{'iid': 's_15143', 'name': 'dungeness crab- cooked&', 'qty': 1.0, 'unit': '', 'raw': '1 DUNGENESS CRAB- COOKED& SHELLED'}, {'iid': 's_20035', 'name': 'quinoa', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup QUINOA'}, {'iid': 's_9206', 'name': 'orange juice', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup ORANGE JUICE'}, {'iid': 's_6172', 'name': 'chicken stock', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup CHICKEN STOCK'}, {'iid': 's_9176', 'name': 'mango', 'qty': 1.0, 'unit': '', 'raw': '1 MANGO- PITTED AND DICED'}, {'iid': 's_11819', 'name': 'fresno chile', 'qty': 1.0, 'unit': '', 'raw': '1 FRESNO CHILE SEEDED, STEMMED& DICED'}, {'iid': 's_9037', 'name': 'avocado', 'qty': 1.0, 'unit': '', 'raw': '1 AVOCADO, SEEDED AND DICED'}, {'iid': 's_9159', 'name': 'lime', 'qty': 1.0, 'unit': '', 'raw': '1 LIME'}, {'iid': 's_10211529', 'name': 'roma tomato', 'qty': 1.0, 'unit': '', 'raw': '1 ROMA TOMATO DICED'}, {'iid': 's_11165', 'name': 'cilantro', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon CHOPPED CILANTRO'}, {'iid': 's_11291', 'name': 'green onion', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon CHOPPED GREEN ONION'}, {'iid': 's_10211215', 'name': 'clove garlic', 'qty': 1.0, 'unit': '', 'raw': '1 MINCED CLOVE GARLIC'}, {'iid': 's_15076', 'name': 'salmon', 'qty': 3.0, 'unit': 'servings', 'raw': 'FRESH SALMON- DICED (OPTIONAL)'}]}, {'rid': 's_636604', 'title': 'Butternut Squash Tofu Salad With Toasted Hazelnuts', 'inst': 'Preheat oven at 370 degree Fahrenheit. Prepare 2 cookie sheets with a liner/parchment paper.In one cookie sheet spread the tofu pieces and in another cookie sheet spread the hazelnuts. Put the cookie sheets in the oven and bake. Bake hazelnuts for 5-7 minutes and tofu for 20 minutes.In the meantime combine water and squash in a saucepan. Cover and boil for 5 minutes or until the squash pieces are soft.When the squash is boiled let it cool for a while and grind into a smooth paste.In a bowl combine salt, black pepper, rosemary, lemon juice and  squash puree and keep it aside.When the hazelnuts are done take it out of the oven and let the tofu cook in the same oven. Let the nuts cool and rub gently between palms or with paper towel to remove the skin.Once the tofu is cooked for 20 minutes or until very light golden brown in color take it out from the oven.In salad bowl combine all the ingredients and mix gently so that the tofu retains its shape. Garnish with more hazelnuts and/or rosemary and serve immediately.This salad tastes great when warm but can be served at room temperature also.', 'serv': 4, 'url': 'https://www.foodista.com/recipe/ZXS8QYZ6/butternut-squash-tofu-salad-with-toasted-hazelnuts', 'cui': '', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ings': [{'iid': 's_1002030', 'name': 'pepper', 'qty': 0.5, 'unit': 'tsp', 'raw': '½ tsp black pepper'}, {'iid': 's_11485', 'name': 'butternut squash', 'qty': 1.0, 'unit': '', 'raw': '1 whole butternut squash, peeled and cut into ½ inch cubes (about 3 cups chopped)'}, {'iid': 's_16163', 'name': 'extra tofu', 'qty': 14.0, 'unit': 'oz', 'raw': '14 oz extra firm tofu'}, {'iid': 's_9152', 'name': 'lemon juice', 'qty': 0.25, 'unit': 'tsp', 'raw': '¼ tsp lemon juice'}, {'iid': 's_12135', 'name': 'hazel nuts', 'qty': 0.5, 'unit': 'cup', 'raw': '½ cup raw hazel nuts'}, {'iid': 's_10211821', 'name': 'bell pepper', 'qty': 1.0, 'unit': '', 'raw': '1 whole red pepper (chopped)'}, {'iid': 's_10011282', 'name': 'onions', 'qty': 0.5, 'unit': '', 'raw': '½ whole red onions (finely sliced)'}, {'iid': 's_2036', 'name': 'rosemary leaves', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp rosemary leaves'}, {'iid': 's_2047', 'name': 'salt', 'qty': 4.0, 'unit': 'servings', 'raw': 'Salt to taste'}, {'iid': 's_14412', 'name': 'water', 'qty': 0.5, 'unit': 'cup', 'raw': '½ cup water'}]}, {'rid': 's_663985', 'title': 'Turkey and Rice Stuffed Acorn Squash', 'inst': 'Prepare rice according to package instructions. (I either cook the rice in chicken stock, or this time I used water and added 1 tablespoon vegeta seasoning to the water to add flavor to the rice as it cooks.) Meanwhile preheat oven to 375 degrees. Cut squash in half and drizzle with olive oil, salt and pepper. Roast skin side down for 30 minutes. Heat 1 tablespoon olive oil in large skilled. Add diced onions. Cook until translucent. Add garlic and cook for 1 minute longer. Add turkey, 1 tablespoon vegeta, red pepper, salt and pepper. Cook until turkey is browned and almost cooked through. Rough chop the mushrooms and add to the pan. Cook until mushrooms are softened. Add rice and spinach and stir until spinach is just wilted. Stuff the squash with the meat and rice mixture and top with bread crumbs. (Either toss bread crumbs with 2 teaspoons olive oil, or I just spray them with spray olive oil to make sure that they brown in the oven. Bake stuffed squash in oven until bread crumbs are browned.', 'serv': 6, 'url': 'https://www.foodista.com/recipe/8QRN8DXZ/turkey-and-rice-stuffed-acorn-squash', 'cui': '', 'diets': ['dairy free'], 'ings': [{'iid': 's_4053', 'name': 'olive oil', 'qty': 3.0, 'unit': 'tablespoons', 'raw': '3 tablespoons olive oil'}, {'iid': 's_11482', 'name': 'acorn squash', 'qty': 3.0, 'unit': 'small', 'raw': '3 smalls acorn squash'}, {'iid': 's_10020444', 'name': 'brown basmati rice', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup brown basmati rice'}, {'iid': 's_11282', 'name': 'onion', 'qty': 1.0, 'unit': 'small', 'raw': '1 small onion'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 2.0, 'unit': 'cloves', 'raw': '2 cloves garlic'}, {'iid': 's_5662', 'name': 'ground turkey', 'qty': 1.25, 'unit': 'pounds', 'raw': '1 1/4 pounds (or 1 package) lean ground turkey'}, {'iid': 's_11266', 'name': 'baby bella mushrooms', 'qty': 1.0, 'unit': 'package', 'raw': '1 package baby bella mushrooms'}, {'iid': 's_10011457', 'name': 'spinach', 'qty': 1.0, 'unit': 'bag', 'raw': '1 bag spinach'}, {'iid': 's_98990', 'name': 'vegeta seasoning', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons vegeta seasoning'}, {'iid': 's_10211821', 'name': 'bell pepper flakes', 'qty': 0.5, 'unit': 'teaspoon', 'raw': '1/2 teaspoon bell pepper flakes'}, {'iid': 's_1102047', 'name': 'salt and pepper', 'qty': 6.0, 'unit': 'servings', 'raw': 'Salt and pepper'}, {'iid': 's_99025', 'name': 'bread crumbs', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup whole wheat bread crumbs'}]}, {'rid': 's_659689', 'title': 'Seasonal Autumn Stew', 'inst': 'In a large soup pot, heat the olive oil over a medium heat. Cook onions, stirring, until golden and beginning to caramelize. Add garlic, fennel, squash, parsnip, rosemary, bay leaves, salt and pepper. Continue to cook for about five minutes until the vegetables start to soften. Add stock, pureed tomatoes and chili flakes. Cover and simmer until the vegetables are tender, about 15 minutes.Meanwhile, saute thinly sliced mushrooms in a little olive oil and butter until they start to brown.Once the vegetables are tender, add mushrooms and kale to the stew along with a pinch or two of cinnamon. Taste and adjust seasoning, adding more salt, pepper or chili flakes if needed.Try serving topped with a little Italian flat leaf parsley and sour cream and whole wheat bread on the side', 'serv': 4, 'url': 'https://www.foodista.com/recipe/CS67PMR7/seasonal-autumn-stew', 'cui': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'whole 30', 'vegan'], 'ings': [{'iid': 's_2004', 'name': 'bay leaves', 'qty': 2.0, 'unit': '', 'raw': '2 bay leaves'}, {'iid': 's_11485', 'name': 'butternut squash', 'qty': 1.0, 'unit': 'medium', 'raw': '1 medium butternut squash, cubed'}, {'iid': 's_10011693', 'name': 'canned tomatoes', 'qty': 1.0, 'unit': 'can', 'raw': '1 can (28 oz, 796 ml) whole tomatoes, pureed'}, {'iid': 's_1032009', 'name': 'chili flakes', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon chili flakes'}, {'iid': 's_2010', 'name': 'cinnamon', 'qty': 1.0, 'unit': 'pinches', 'raw': '1 pinches of cinnamon'}, {'iid': 's_11957', 'name': 'fennel bulb', 'qty': 1.0, 'unit': '', 'raw': '1 fennel bulb, thinly sliced'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 2.0, 'unit': 'cloves', 'raw': '2 cloves garlic, minced'}, {'iid': 's_11233', 'name': 'kale', 'qty': 0.5, 'unit': 'bunch', 'raw': '1/2 bunch of kale'}, {'iid': 's_11260', 'name': 'mushrooms', 'qty': 2.0, 'unit': 'cups', 'raw': '2 cups mushrooms, thinly sliced'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon olive oil'}, {'iid': 's_11282', 'name': 'onion', 'qty': 1.0, 'unit': '', 'raw': '1 onion, diced'}, {'iid': 's_11298', 'name': 'parsnip', 'qty': 1.0, 'unit': '', 'raw': '1 parsnip, cored and diced'}, {'iid': 's_2036', 'name': 'rosemary', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon rosemary, minced'}, {'iid': 's_1102047', 'name': 'salt and pepper', 'qty': 4.0, 'unit': 'servings', 'raw': 'salt and pepper to taste'}, {'iid': 's_6615', 'name': 'vegetable broth', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup vegetable broth'}]}, {'rid': 's_640921', 'title': 'Stuffed Artichoke Main Dish', 'inst': "Pull apart center leaves of artichoke Cut the center so that you take the prickly center Use spoon to get all that out so you only have the center being empty Add a bit of lemon juice to make sure it doesn't change color Add artichoke to boiling water Let boil for 10 min so it gets kind of soft Take out Add cold water so it cools Cut the edges of artichoke How to make the stuffing.Boil the potato, or put into microwave to cook it up. (it just needs to be soft)In a sauce pan at med-high heat add the olive oil, rosemary, maple syrup, crushed and finely sliced garlic and the chicken. Add the lemon sliced  up to the saucepan and cook it all together for for 15 min. So that it is all cooked up.  and put it onto a plate to cool.Now there should be some sauce still left in the pan, so slice the cooked potatoe and add it to the pan to get all that tasty sauce.Now cut up the chicken, potato and some grated mozzarella cheese and mash it up so that you can stuff it into the artichoke. Bake in oven at 350 for 20ish min.", 'serv': 2, 'url': 'https://www.foodista.com/recipe/X8NMGGCS/crown-chokes', 'cui': '', 'diets': ['gluten free'], 'ings': [{'iid': 's_11007', 'name': 'artichoke', 'qty': 1.0, 'unit': '', 'raw': '1 Large Artichoke'}, {'iid': 's_5062', 'name': 'chicken breasts', 'qty': 2.0, 'unit': '', 'raw': '2 chicken breasts'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 2.0, 'unit': 'cloves', 'raw': '2 cloves of garlic'}, {'iid': 's_9150', 'name': 'lemon', 'qty': 1.0, 'unit': '', 'raw': '1 lemon'}, {'iid': 's_19911', 'name': 'maple syrup', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of maple syrup'}, {'iid': 's_4053', 'name': 'olive olive oil', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of olive olive oil'}, {'iid': 's_1033', 'name': 'parmesan', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon Parmesan'}, {'iid': 's_10211821', 'name': 'bell pepper', 'qty': 2.0, 'unit': 'servings', 'raw': 'pepper'}, {'iid': 's_11352', 'name': 'potato', 'qty': 1.0, 'unit': 'large', 'raw': '1 large potato'}, {'iid': 's_2036', 'name': 'rosemary', 'qty': 1.0, 'unit': 'sprig', 'raw': '1 sprig of rosemary'}, {'iid': 's_2047', 'name': 'salt', 'qty': 2.0, 'unit': 'servings', 'raw': 'salt'}, {'iid': 's_1001026', 'name': 'mozzarella cheese', 'qty': 1.0, 'unit': 'handful', 'raw': '1 handful shredded mozzarella cheese'}]}, {'rid': 's_644390', 'title': 'Garlicky Roasted Kale', 'inst': 'Whisk vinegar and olive oil until incorporated.Coat both sides of each piece of kale, and lay them on a parchment paper covered baking sheets. Sprinkle with garlic powder, cayenne and a pinch of kosher salt. Bake for 10-15 minutes, or until leaves have browned, in a preheated 350 degree oven.   Toss halfway through so both sides get crispy.', 'serv': 2, 'url': 'https://www.foodista.com/recipe/86RJVKPG/garlicky-roasted-kale', 'cui': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'whole 30', 'vegan'], 'ings': [{'iid': 's_2048', 'name': 'apple cider vinegar', 'qty': 4.0, 'unit': 'tablespoons', 'raw': '4 tablespoons apple cider vinegar'}, {'iid': 's_2031', 'name': 'cayenne powder', 'qty': 2.0, 'unit': 'servings', 'raw': 'Cayenne powder'}, {'iid': 's_1022020', 'name': 'garlic powder', 'qty': 2.0, 'unit': 'servings', 'raw': 'Garlic powder'}, {'iid': 's_11233', 'name': 'kale leaves', 'qty': 10.0, 'unit': '', 'raw': '10 kale leaves (de-stemmed), cut into pieces'}, {'iid': 's_1082047', 'name': 'kosher salt', 'qty': 2.0, 'unit': 'servings', 'raw': 'Kosher salt'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons olive oil'}]}, {'rid': 's_982382', 'title': 'Instant Pot Chicken Taco Soup', 'inst': 'Press the Saute button on the Instant Pot and heat oil. Add onion and bell pepper and saute until translucent. Add tomatoes including juice and add water. Make sure to scrape all of the bits from the sides and bottom of the Instant Pot as you are stirring. Add chicken, chili powder, corn, black beans, green onions, green chilis, and  cup of cilantro. Lock lid. Press the manual or pressure cook button and set time for 15 minutes. When time is up, do a quick release until the valve drops and then unlock the lid. Shred the chicken using two forks and then let the soup simmer for 5 minutes. Serve the soup into bowls and then top with your favorite toppings such as sour cream, cheese, avocado, etc.', 'serv': 4, 'url': 'https://www.pinkwhen.com/instant-pot-chicken-taco-soup/', 'cui': 'mexican', 'diets': ['gluten free', 'dairy free'], 'ings': [{'iid': 's_1055062', 'name': 'boneless/skinless chicken breasts', 'qty': 0.5, 'unit': 'pound', 'raw': '½ pound boneless/skinless chicken breasts'}, {'iid': 's_16018', 'name': 'black beans', 'qty': 10.0, 'unit': 'oz', 'raw': '1 10 oz can of black beans'}, {'iid': 's_11177', 'name': 'corn', 'qty': 10.0, 'unit': 'oz', 'raw': '1 10 oz can of corn'}, {'iid': 's_11980', 'name': 'chilis', 'qty': 4.0, 'unit': 'oz', 'raw': '1 4oz can chopped green chilis'}, {'iid': 's_10011693', 'name': 'canned tomatoes', 'qty': 28.0, 'unit': 'oz', 'raw': '1 28oz can diced tomatoes'}, {'iid': 's_2009', 'name': 'chili powder', 'qty': 2.0, 'unit': 'tsp', 'raw': '2 tsp chili powder'}, {'iid': 's_2012', 'name': 'cilantro', 'qty': 0.25, 'unit': 'cup', 'raw': '¼ cup dried cilantro'}, {'iid': 's_11333', 'name': 'bell pepper', 'qty': 1.0, 'unit': 'medium', 'raw': '1 medium green bell pepper finely chopped'}, {'iid': 's_11291', 'name': 'green onion', 'qty': 0.25, 'unit': 'cup', 'raw': '¼ cup chopped green onion'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 1.0, 'unit': 'tbsp', 'raw': '1 tbsp olive oil'}, {'iid': 's_11282', 'name': 'onion', 'qty': 1.0, 'unit': '', 'raw': '1 onion finely chopped'}, {'iid': 's_14412', 'name': 'water', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup water'}]}, {'rid': 's_652038', 'title': 'Minted Pea & Spinach Soup', 'inst': "Place pototoes in a medium sized pot with a little bit of water and some salt & pepper. Place lid on and cook for 20 minutes until almost soft. Add peas and cook for a further 5 minutes until potatoes are soft and cooked through. Add spinach and cook a further 3 -5 minutes, until wilted.Take off the heat and let cool for a few minutes, then blend to a puree with an immersion blender. Place pot back on the stovetop, adding cream, milk, water and chicken stock. Re-heat for a few minutes until piping-hot. Add yoghurt, mint, sugar, salt and pepper to taste and stir through. Serve immediately, scattered with some crispy croutons or bacon bits (or if you're like me and you just have some cheesegrillers on hand, fry them up in thin slices with a bit of sweet chilli sauce and use as topper).", 'serv': 6, 'url': 'https://www.foodista.com/recipe/QGDZZM3X/minted-pea-spinach-soup', 'cui': '', 'diets': ['gluten free', 'lacto ovo vegetarian'], 'ings': [{'iid': 's_6172', 'name': 'chicken stock', 'qty': 1.0, 'unit': 'cube', 'raw': '1 cube chicken stock'}, {'iid': 's_1053', 'name': 'cream', 'qty': 0.25, 'unit': 'cup', 'raw': '1/4 cup cream'}, {'iid': 's_2066', 'name': 'mint', 'qty': 2.0, 'unit': 'teaspoons', 'raw': '2 teaspoons dried mint (I like mint a lot, but you can use less if you prefer)'}, {'iid': 's_1077', 'name': 'milk', 'qty': 0.25, 'unit': 'cup', 'raw': '1/4 cup milk'}, {'iid': 's_11304', 'name': 'peas', 'qty': 1.0, 'unit': 'lb', 'raw': '500 grams (1 lb) frozen peas'}, {'iid': 's_11352', 'name': 'potatoes', 'qty': 2.0, 'unit': 'medium', 'raw': '2 mediums potatoes, diced'}, {'iid': 's_1102047', 'name': 'salt & pepper', 'qty': 6.0, 'unit': 'servings', 'raw': 'salt & pepper to taste'}, {'iid': 's_10011457', 'name': 'spinach', 'qty': 0.5, 'unit': 'pound', 'raw': '250 grams (½ pound) fresh spinach, chopped'}, {'iid': 's_19335', 'name': 'sugar', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons sugar'}, {'iid': 's_14412', 'name': 'water', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup water (add more or less, depending on how thick you like your soup)'}, {'iid': 's_1116', 'name': 'yoghurt', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons yoghurt'}]}, {'rid': 's_661365', 'title': 'Spinach, Tomato & Onion Couscous', 'inst': 'Bring the water, along with half the salt, to a boil in a small pan.  Once boiling, add the couscous, stir and cover with a lid. Remove the pot from the heat, and allow it to sit for the 5 to 7 minutes it takes to cook the vegetables. Heat a large pan over medium-high heat and add the 2 tablespoons of olive oil.  Once the oil is hot, add the onions and saut until they begin to brown. Add the tomatoes and remaining salt and saut until they begin to wilt, about 20 to 30 seconds. Add the spinach and saut just until it wilts but remains bright green. Finally, stir the pine nuts into the vegetable mixture and remove the pan from the heat.  Season with salt and pepper to taste. Pour the couscous into a large bowl, add the sauted vegetables along with the crumbled feta and toss everything together.  Top with the extra crumbled feta and enjoy while hot.', 'serv': 3, 'url': 'https://www.foodista.com/recipe/SVZDH8S4/spinach-tomato-onion-couscous', 'cui': '', 'diets': ['lacto ovo vegetarian'], 'ings': [{'iid': 's_1019', 'name': 'feta', 'qty': 0.5, 'unit': 'cup', 'raw': "1/2 cup feta (preferably goat or sheep's milk) crumbled, plus extra for garnish"}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons olive oil'}, {'iid': 's_12147', 'name': 'pine nuts', 'qty': 0.25, 'unit': 'cup', 'raw': '1/4 cup pine nuts'}, {'iid': 's_10011282', 'name': 'onion', 'qty': 1.0, 'unit': 'small', 'raw': '1 small large red onion, chopped into pieces'}, {'iid': 's_2047', 'name': 'salt', 'qty': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon salt'}, {'iid': 's_10011457', 'name': 'spinach', 'qty': 5.0, 'unit': 'cups', 'raw': '5 cups fresh spinach, thoroughly washed'}, {'iid': 's_9316', 'name': 'tomatoes', 'qty': 0.5, 'unit': 'pound', 'raw': '1/2 pound ripe small tomatoes (preferably strawberry, cherry or'}, {'iid': 's_14412', 'name': 'water', 'qty': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups water'}, {'iid': 's_99024', 'name': 'couscous', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup whole-wheat couscous'}]}, {'rid': 's_641072', 'title': 'Curried Chickpeas and Vegetables', 'inst': "Saute garlic and onions in the oil. After you sweat the onions, add spices (cumin, curry, and garam masala). Add water, bouillon cubes, ginger, garbanzo beans/chickpeas, potatoes, and veggies. Boil and simmer for about 25 minutes, or until all of the veggies are cooked. Add fresh cilantro and cook for about 10 minutes more. Serve with pita, vegan na'an, basamati rice, brown rice, or quinoa.  Note:  I didn't have time to make home made vegan na'an, so I just purchased a multi-grain pizza dough from the deli.  Directions: 1 small tennis ball sized dough, flatten, cover with flour, and season with olive oil, garlic powder, and a bit of salt. Enjoy!", 'serv': 2, 'url': 'https://www.foodista.com/recipe/HD7DHP8M/curried-chickpeas-and-vegetables', 'cui': '', 'diets': ['gluten free', 'dairy free'], 'ings': [{'iid': 's_16057', 'name': 'chickpeas/garbanzo beans', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup of cooked chickpeas/garbanzo beans'}, {'iid': 's_11352', 'name': 'potatoes', 'qty': 2.0, 'unit': '', 'raw': '2 potatoes (cubed)'}, {'iid': 's_14412', 'name': 'water', 'qty': 4.0, 'unit': 'cups', 'raw': '4 cups of water'}, {'iid': 's_5006', 'name': 'not chicken" vegan bouillons', 'qty': 3.0, 'unit': 'cubes', 'raw': '3 cubes of" NOT BEEF or NOT CHICKEN" vegan bouillons.'}, {'iid': 's_11282', 'name': 'onion', 'qty': 0.5, 'unit': 'medium', 'raw': '1/2 medium onion (diced)'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 2.0, 'unit': 'cloves', 'raw': '2 cloves of garlic'}, {'iid': 's_10011693', 'name': 'canned tomatoes', 'qty': 6.0, 'unit': 'oz', 'raw': '6 oz can of diced tomatoes or pureed tomatoes'}, {'iid': 's_11165', 'name': 'veggies', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup of veggies (zucchini, carrots, 1 cup of fresh cilantro'}, {'iid': 's_2021', 'name': 'ground ginger', 'qty': 1.5, 'unit': 'tablespoons', 'raw': '1 1/2 tablespoons of fresh ground ginger'}, {'iid': 's_1002014', 'name': 'cumin', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of cumin'}, {'iid': 's_2015', 'name': 'curry powder', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons of curry powder'}, {'iid': 's_93663', 'name': 'garam masala', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon of garam masala'}, {'iid': 's_93767', 'name': 'pepper and liquid aminos', 'qty': 2.0, 'unit': 'servings', 'raw': 'Pepper and liquid aminos (for salt) to taste'}, {'iid': 's_4517', 'name': 'oil', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon of oil (preferably grape seed oil or olive oil)'}]}, {'rid': 's_646930', 'title': 'Homemade Broccoli Cheddar Soup', 'inst': 'In your soup pot, saute over med-high heat: 2 Tbsp of your olive oil with the shallot, onion and jalapeno. When cooked lightly, add in lemon juice, veggie broth, remaining oil, salt and pepper. Reduce heat to medium. Add Potatoes and bring broth to a boil. Cook until potatoes are tender. Add chopped Broccoli (florets and steams). Remember to leave out a few florets for later use though.Cover with lid, when broccoli is tender, turn heat off. Transfer contents of pot into a large mixing bowl. Allow to cool slightly. Add to the bowl the fresh parsley, Chobani and almond milk. Fold new ingredients into the hot soup mixture. In batches, puree the soup in a food-processor (maybe someday soon, a Vitamix!) style blender. Soup should be smooth-no lumps or chunks. In the soup pot, add the broccoli florets, a dash of veggie broth and saute covered for about a minute until tender. Add the pureed soup back into the soup pot. Add a bay leaf and a few pinches of chopped basil (optional). Simmer uncovered for at least twenty minutes to cook out all the air bubbles. Stir constantly for the first few minutes. Remove the bay leaf before serving or storing.', 'serv': 4, 'url': 'https://www.foodista.com/recipe/Y37ZMBWN/homemade-broccoli-cheddar-soup', 'cui': '', 'diets': ['gluten free'], 'ings': [{'iid': 's_11090', 'name': 'broccoli', 'qty': 8.0, 'unit': 'cups', 'raw': '8 cups raw broccoli, florets and stalk, chopped'}, {'iid': 's_11677', 'name': 'shallot', 'qty': 1.0, 'unit': '', 'raw': '1 shallot, chopped'}, {'iid': 's_9152', 'name': 'juice of lemon', 'qty': 1.0, 'unit': '', 'raw': '1 lemon, juiced'}, {'iid': 's_6615', 'name': 'vegetable broth', 'qty': 3.0, 'unit': 'cups', 'raw': '3 cups vegetable broth'}, {'iid': 's_1002030', 'name': 'pepper', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon pepper'}, {'iid': 's_2047', 'name': 'salt', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon salt'}, {'iid': 's_10011282', 'name': 'onion', 'qty': 1.0, 'unit': 'small', 'raw': '1 small red onion, chopped'}, {'iid': 's_1001116', 'name': 'yogurt', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup plain yogurt'}, {'iid': 's_10211362', 'name': 'yukon gold potatoes', 'qty': 3.0, 'unit': 'cups', 'raw': '3 cups Yukon Gold potatoes, rough chop (skin on)'}, {'iid': 's_11297', 'name': 'parsley', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup parsley'}, {'iid': 's_2004', 'name': 'bay leaf', 'qty': 1.0, 'unit': '', 'raw': '1 bay leaf'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup olive oil'}, {'iid': 's_93607', 'name': 'almond milk', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup almond milk, plain flavor'}, {'iid': 's_1001009', 'name': 'cheddar cheese', 'qty': 1.5, 'unit': 'cups', 'raw': '1 1/2 cups shredded cheddar cheese'}]}, {'rid': 's_648279', 'title': 'Italian Tuna Pasta', 'inst': 'Once pasta is cooked, drain and leave to cool for a minute. Place small skillet on medium fire, drizzle olive oil, add in red pepper and stir-fry for 1-2 minutes. Put aside.Toss pasta shells, red pepper, tuna, parsley, garlic, chillies and lemon juice. Season with ground black pepper to taste, spoon into serving bowls.', 'serv': 3, 'url': 'https://www.foodista.com/recipe/4QNQXMDZ/italian-tuna-pasta', 'cui': 'mediterranean', 'diets': ['dairy free', 'pescatarian'], 'ings': [{'iid': 's_11819', 'name': 'chillies', 'qty': 2.0, 'unit': '', 'raw': '2 fresh chillies'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon minced garlic'}, {'iid': 's_1002030', 'name': 'ground pepper', 'qty': 3.0, 'unit': 'servings', 'raw': 'Ground black pepper'}, {'iid': 's_9152', 'name': 'juice of lemon', 'qty': 2.0, 'unit': '', 'raw': '2 lemons, juiced'}, {'iid': 's_11297', 'name': 'parsley leaves', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup of chopped parsley leaves'}, {'iid': 's_11020420', 'name': 'pasta shells', 'qty': 250.0, 'unit': 'grams', 'raw': "250 grams of pasta shells (cook pasta according to packet's instructions)"}, {'iid': 's_11821', 'name': 'bell pepper', 'qty': 1.0, 'unit': '', 'raw': '1 red pepper'}, {'iid': 's_10015121', 'name': 'tuna', 'qty': 400.0, 'unit': 'grams', 'raw': '400 grams of tuna, drained and flaked'}]}, {'rid': 's_660736', 'title': 'Soy Ginger Glazed Halibut with Ginger Peach Relish', 'inst': 'Peel and roughly chop a piece of ginger. Place all marinade ingredients (soy sauce, white wine, olive oil, and 1 tablespoon chopped ginger) in a blender and blend until smooth. This step is important in order to get the ginger pulp and juices to infuse into the marinade. In a zip-lock bag (or bowl that you can cover) add the halibut fillets and marinade. Allow the fish to marinate for at least 20 minutes, but several hours is preferred if you are able to do this step ahead of time.Set your oven to broil, allow it to warm up then place the fish in a casserole dish with all of the marinade. Place the casserole dish on one of the top racks and allow to bake about 10-12 minutes, until there is a nice brown glaze on top and fish is cooked all the way through.To make the ginger peach relish, combine the chopped peach, red onion, jalapeno, apple cider vinegar, the juice of the half lime, and 1 tablespoon of ginger in a bowl, stir and refrigerate until ready to use.  Allowing the relish to sit for a few hours before consuming gives the flavors time to combine.', 'serv': 2, 'url': 'https://www.foodista.com/recipe/2DVW5R35/soy-ginger-glazed-halibut-w-ginger-peach-relish', 'cui': '', 'diets': ['gluten free', 'dairy free', 'pescatarian'], 'ings': [{'iid': 's_2048', 'name': 'apple cider vinegar', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons apple cider vinegar'}, {'iid': 's_10211216', 'name': 'ginger', 'qty': 2.0, 'unit': 'tablespoon', 'raw': '2 tablespoon fresh ginger, peeled and finely chopped'}, {'iid': 's_15036', 'name': 'halibut fillets', 'qty': 1.0, 'unit': 'pound', 'raw': '1 pound halibut fillets'}, {'iid': 's_11979', 'name': 'jalapeno', 'qty': 1.0, 'unit': '', 'raw': '1 jalapeno, seeded and finely chopped'}, {'iid': 's_9159', 'name': 'lime', 'qty': 0.5, 'unit': '', 'raw': '1/2 lime'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon olive oil'}, {'iid': 's_9236', 'name': 'peach', 'qty': 1.0, 'unit': 'large', 'raw': '1 large ripe peach'}, {'iid': 's_10011282', 'name': 'onion', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 heaping tablespoon red onion, finely chopped'}, {'iid': 's_16124', 'name': 'soy sauce', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup Soy Sauce'}, {'iid': 's_14134', 'name': 'white wine', 'qty': 0.25, 'unit': 'cup', 'raw': '¼ cup white wine (I used sauvignon blanc)'}]}, {'rid': 's_633754', 'title': 'Baked Ratatouille', 'inst': 'Heat oil in a heavy, large Dutch oven over medium heat. Add garlic; stir 1 minute. Add eggplant, green bell peppers, tomatoes, onion, zucchini and basil. Saute for 5 minutes. Cover and simmer until all vegetables are tender, stirring occasionally, about 25 minutes.Uncover pot and simmer until juice thickens, stirring occasionally, about 10 minutes. Mix in vinegar; season to taste with salt and pepper.Preheat oven to 350 degrees. Spread in 9-inch pie dish. Sprinkle with cheese, if desired. Bake until heated through, about 20 minutes.This recipe yields about 3 cups.', 'serv': 1, 'url': 'https://www.foodista.com/recipe/24CCF5WL/baked-ratatouille', 'cui': 'mediterranean', 'diets': ['gluten free', 'lacto ovo vegetarian', 'primal'], 'ings': [{'iid': 's_11209', 'name': 'eggplant', 'qty': 1.0, 'unit': 'large', 'raw': '1 large eggplant unpeeled, diced'}, {'iid': 's_1019', 'name': 'feta cheese', 'qty': 4.0, 'unit': 'ounces', 'raw': '4 ounces diced feta cheese (optional)'}, {'iid': 's_2044', 'name': 'basil', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup chopped fresh basil'}, {'iid': 's_10211215', 'name': 'garlic cloves', 'qty': 5.0, 'unit': '', 'raw': '5 garlic cloves chopped'}, {'iid': 's_11333', 'name': 'bell peppers', 'qty': 2.0, 'unit': '', 'raw': '2 green bell peppers diced'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 3.0, 'unit': 'tablespoons', 'raw': '3 tablespoons Olive Oil'}, {'iid': 's_11282', 'name': 'onion cut " pieces', 'qty': 1.0, 'unit': '', 'raw': '1 onion cut 1" pieces'}, {'iid': 's_1022068', 'name': 'red wine vinegar', 'qty': 2.0, 'unit': 'tablespoons', 'raw': '2 tablespoons red wine vinegar'}, {'iid': 's_11529', 'name': 'tomatoes', 'qty': 2.0, 'unit': 'large', 'raw': '2 large tomatoes chopped'}, {'iid': 's_11477', 'name': 'zucchini cut', 'qty': 1.0, 'unit': 'large', 'raw': '1 large zucchini cut 1/2" pieces'}]}, {'rid': 's_661074', 'title': 'Spicy Cauliflower', 'inst': 'Pre-heat the oven to 350 F. Clean and cut the cauliflower florets. Place the florets in a oven pan, sprinkle them with paprika, curry And salt and bake in the oven for 15 minutes. Meanwhile, chop the Shallots and wild mushrooms and saute them fro 5 minutes, or until Golden brown. Serve the cauliflower tossed with the mushrooms and Shallots, toped with chopped parsley and lemon juice.', 'serv': 2, 'url': 'https://www.foodista.com/recipe/FZTFNV4N/spicy-coliflower', 'cui': '', 'diets': ['gluten free', 'dairy free', 'paleolithic', 'lacto ovo vegetarian', 'primal', 'whole 30', 'vegan'], 'ings': [{'iid': 's_11135', 'name': 'cauliflower', 'qty': 1.0, 'unit': '', 'raw': '1 cauliflower'}, {'iid': 's_2015', 'name': 'indian curry powder', 'qty': 1.0, 'unit': 'tablespoon', 'raw': '1 tablespoon of Indian curry powder'}, {'iid': 's_9150', 'name': 'lemon', 'qty': 2.0, 'unit': 'servings', 'raw': 'Lemon'}, {'iid': 's_11260', 'name': 'mushrooms', 'qty': 0.5, 'unit': 'cup', 'raw': '1/2 cup wild mushrooms'}, {'iid': 's_2028', 'name': 'paprika', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon paprika'}, {'iid': 's_11297', 'name': 'parsley', 'qty': 2.0, 'unit': 'servings', 'raw': 'Parsley'}, {'iid': 's_2047', 'name': 'salt', 'qty': 2.0, 'unit': 'servings', 'raw': 'Salt to taste'}, {'iid': 's_11677', 'name': 'shallots', 'qty': 2.0, 'unit': '', 'raw': '2 shallots'}]}, {'rid': 's_633766', 'title': 'Baked Rigatoni', 'inst': 'Preheat oven to 400 degrees. Cook pasta according to package directions, drain. Combine pasta, pasta sauce, tomatoes, broccoli, burger crumbles, basil, fennel seeds and 4 oz. of the mozzarella in a 9x13 baking dish. Top with remaining 2 oz. mozzarella. Bake until heated through, about 20 minutes.', 'serv': 6, 'url': 'https://www.foodista.com/recipe/78KGC5QF/baked-rigatoni', 'cui': '', 'diets': ['lacto ovo vegetarian'], 'ings': [{'iid': 's_11090', 'name': 'broccoli flowerets', 'qty': 14.0, 'unit': 'ounces', 'raw': '14 ounces frozen broccoli flowerets'}, {'iid': 's_2003', 'name': 'basil', 'qty': 1.0, 'unit': 'teaspoon', 'raw': '1 teaspoon dried basil'}, {'iid': 's_2018', 'name': 'fennel seeds', 'qty': 0.25, 'unit': 'teaspoon', 'raw': '1/4 teaspoon fennel seeds'}, {'iid': 's_10011549', 'name': 'pasta sauce', 'qty': 26.0, 'unit': 'ounces', 'raw': '26 ounces pasta sauce'}, {'iid': 's_11220420', 'name': 'rigatoni', 'qty': 1.0, 'unit': 'pound', 'raw': '1 pound rigatoni'}, {'iid': 's_1001026', 'name': 'mozzarella cheese', 'qty': 6.0, 'unit': 'ounces', 'raw': '6 ounces mozzarella cheese, part skim milk shredded'}, {'iid': 's_11529', 'name': 'ready-cut tomatoes', 'qty': 14.5, 'unit': 'ounces', 'raw': '14 1/2 ounces canned ready-cut diced tomatoes drained'}, {'iid': 's_16147', 'name': 'vegetable burger crumbles', 'qty': 6.0, 'unit': 'ounces', 'raw': '6 ounces frozen vegetable burger crumbles'}]}, {'rid': 's_1096185', 'title': 'North by Northwest Couscous Salad', 'inst': 'Whisk together the lemon zest, lemon juice, sugar, mustard, and salt.Slowly add in the olive oil, continuing to whisk, until emulsified.Prepare the couscous according to the package instructions.Toast the hazelnuts for approximately 10 minutes at 350F. Let cool until safe to touch, then chop. Mix all remaining ingredients in a large bowl. Add the couscous and dressing. Mix well and serve.', 'serv': 4, 'url': 'https://www.foodista.com/recipe/8S3RLBHN/north-by-northwest-couscous-salad', 'cui': '', 'diets': ['dairy free', 'lacto ovo vegetarian', 'vegan'], 'ings': [{'iid': 's_9156', 'name': 'lemon zest', 'qty': 0.5, 'unit': 'tsp', 'raw': '½ tsp lemon zest'}, {'iid': 's_9152', 'name': 'squeezed lemon juice', 'qty': 2.0, 'unit': 'tbs', 'raw': '2 Tbs fresh squeezed lemon juice'}, {'iid': 's_19335', 'name': 'sugar', 'qty': 1.0, 'unit': 'tsp', 'raw': '1 tsp sugar'}, {'iid': 's_1032046', 'name': 'dijon mustard', 'qty': 0.5, 'unit': 'tsp', 'raw': '½ tsp Dijon mustard'}, {'iid': 's_1082047', 'name': 'kosher salt', 'qty': 0.25, 'unit': 'tsp', 'raw': '¼ tsp Kosher salt'}, {'iid': 's_1002030', 'name': 'pepper', 'qty': 4.0, 'unit': 'servings', 'raw': 'freshly ground black pepper'}, {'iid': 's_4053', 'name': 'olive oil', 'qty': 3.0, 'unit': 'tbs', 'raw': '3 Tbs olive oil'}, {'iid': 's_10020028', 'name': 'tri-color pearl couscous', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup Tri-Color Pearl Couscous'}, {'iid': 's_9021', 'name': 'apricots', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup fresh apricots, chopped'}, {'iid': 's_11124', 'name': 'carrots', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup diced carrots'}, {'iid': 's_11143', 'name': 'celery', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup diced celery'}, {'iid': 's_9299', 'name': 'raisins', 'qty': 4.0, 'unit': 'tbs', 'raw': '4 Tbs raisins'}, {'iid': 's_16058', 'name': 'garbanzo beans', 'qty': 1.0, 'unit': 'can', 'raw': '1 can -15oz garbanzo beans'}, {'iid': 's_12120', 'name': 'hazelnuts', 'qty': 1.0, 'unit': 'cup', 'raw': '1 cup whole hazelnuts, toasted and chopped'}, {'iid': 's_10011282', 'name': 'onion', 'qty': 0.33333334, 'unit': 'cup', 'raw': '1/3 cup diced red onion'}, {'iid': 's_11297', 'name': 'parsley', 'qty': 0.5, 'unit': 'cup', 'raw': '½ cup chopped parsley, loosely packed'}]}, {'rid': 's_637157', 'title': 'Carolina Caviar - Black Bean Salsa', 'inst': 'Add all ingredients together in a large bowl; tasting and adjusting as you go! Chill in the refrigerator overnight. Adjust seasoning to preference levels after the salsa sets overnight and the flavors blend/marry. Serve with tortilla chips.', 'serv': 4, 'url': 'https://www.foodista.com/recipe/YX8KH6ZY/carolina-caviar-black-bean-salsa', 'cui': 'mexican', 'diets': ['gluten free', 'dairy free', 'lacto ovo vegetarian', 'vegan'], 'ings': [{'iid': 's_16018', 'name': 'black beans', 'qty': 15.0, 'unit': 'ounce', 'raw': '2 cans (15 ounce) black beans, rinsed and drained'}, {'iid': 's_9037', 'name': 'avocados', 'qty': 2.0, 'unit': '', 'raw': '2 avocados, peeled, cored, sliced and diced'}, {'iid': 's_11951', 'name': 'bell pepper', 'qty': 1.0, 'unit': '', 'raw': '1 yellow bell pepper, cored, seeded, and diced'}, {'iid': 's_10011821', 'name': 'orange bell pepper', 'qty': 1.0, 'unit': '', 'raw': '1 orange bell pepper, cored, seeded, and diced'}, {'iid': 's_11333', 'name': 'bell pepper', 'qty': 1.0, 'unit': '', 'raw': '1 green bell pepper, cored, seeded, and diced'}, {'iid': 's_11291', 'name': 'green onions', 'qty': 1.0, 'unit': 'bunch', 'raw': '1 bunch green onions, sliced'}, {'iid': 's_10011282', 'name': 'onion', 'qty': 0.5, 'unit': '', 'raw': '1/2 of a medium red onion, finely chopped'}, {'iid': 's_11168', 'name': 'package corn', 'qty': 1.0, 'unit': 'can', 'raw': '1 can small package frozen corn, thawed or 1 yellow& white corn'}, {'iid': 's_10011885', 'name': 'rotel tomatoes and chiles', 'qty': 2.0, 'unit': 'cans', 'raw': '2 cans Rotel tomatoes and chiles (be careful, this might be too'}, {'iid': 's_11165', 'name': 'cilantro', 'qty': 1.0, 'unit': 'bunch', 'raw': '1 bunch of fresh cilantro, stems removed, leaves finely chopped'}, {'iid': 's_11215', 'name': 'garlic', 'qty': 4.0, 'unit': 'tablespoons', 'raw': '4 tablespoons minced garlic'}, {'iid': 